# Vox Environment Variables
# Copy this file to .env and fill in your values.
# Run `vox doctor` to verify your setup.
#
# Compose / deployment hub: docs/src/architecture/deployment-compose-ssot.md

# ── AI Provider Keys ──────────────────────────────────────────────────────────

# Google AI Studio (FREE — no credit card required)
# Get your key at: https://aistudio.google.com/apikey (just needs a Google account)
# Provides: Gemini 2.5 Flash-Lite, Flash, Pro — all free with generous rate limits
GEMINI_API_KEY=

# OpenRouter (OPTIONAL — free key unlocks :free models; paid key enables SOTA)
# Get your key at: https://openrouter.ai/keys
# Free models: Devstral 2, Qwen3 Coder, Llama 4 Scout, Kimi K2, and more
# Paid models: DeepSeek v3.2, Claude Sonnet 4.5, GPT-5, O3
OPENROUTER_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────

# Turso remote database (OPTIONAL — defaults to local SQLite at ~/.vox/vox.db)
# Required only for multi-device sync or production deployments
# Get a free database at: https://turso.tech/
VOX_DB_URL=
VOX_DB_TOKEN=
# Optional explicit local DB path (containers / embedded replica)
VOX_DB_PATH=

# ── Server ────────────────────────────────────────────────────────────────────

# Port for the Vox MCP server (default: 3000)
PORT=3000

# ── Inference profile (optional) ─────────────────────────────────────────────
# desktop_ollama | cloud_openai_compatible | mobile_litert | mobile_coreml | lan_gateway
# See docs/src/architecture/mobile-edge-ai-ssot.md
#VOX_INFERENCE_PROFILE=desktop_ollama

# ── Mesh (optional; default off) ───────────────────────────────────────────────
# See docs/src/architecture/mesh-ssot.md — same names as docker/vox-compose-mesh-environment.block.yaml
#VOX_MESH_ENABLED=0
#VOX_MESH_CONTROL_ADDR=http://127.0.0.1:9847
#VOX_ORCHESTRATOR_MESH_CONTROL_URL=http://vox-mesh-ctrl:9847
#VOX_MESH_SCOPE_ID=
#VOX_MESH_TOKEN=
#VOX_MESH_NODE_ID=
#VOX_MESH_LABELS=
#VOX_MESH_REGISTRY_PATH=
#VOX_MESH_ADVERTISE_GPU=0
#VOX_MESH_MAX_STALE_MS=
#VOX_MESH_CODEX_TELEMETRY=0
#VOX_MESH_HTTP_JOIN=   # 0/false to skip HTTP join
#VOX_MESH_HTTP_HEARTBEAT_SECS=30
# Single-container sidecar: Dockerfile entrypoint — docs/src/architecture/mesh-ssot.md
#VOX_MESH_MESH_SIDECAR=0
