{
  "$schema": "./contracts/tokens/tokens.v1.json",
  "color": {
    "primary": "#3a86ff",
    "secondary": "#ff006e",
    "background": "#ffffff",
    "text": {
      "value": "#1d3557",
      "on": "color.background",
      "text_role": "body"
    }
  },
  "spacing": {
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "font": {
    "base": "16px",
    "large": "20px"
  },
  "surface": {
    "default": {
      "$surface_pair": true,
      "fg": "color.text",
      "bg": "color.background"
    },
    "primary": {
      "$surface_pair": true,
      "fg": "color.background",
      "bg": "color.primary"
    },
    "secondary": {
      "$surface_pair": true,
      "fg": "color.background",
      "bg": "color.secondary"
    }
  }
}
