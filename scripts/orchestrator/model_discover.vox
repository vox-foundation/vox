// vox:caps process
import process;

fn main() {
    print("Running Nightly Model Discovery...");
    
    let res = process.run("vox", ["model", "discover"]);
    if res is not null {
        if res.code == 0 {
            print("✅ Model discovery completed successfully.");
        } else {
            print("❌ Model discovery failed with code: " + res.code);
            process.exit(1);
        }
    } else {
        print("❌ Failed to spawn vox process.");
        process.exit(1);
    }
}
