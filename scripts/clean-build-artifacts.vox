// vox:caps fs subprocess env
// Reclaim disk from Cargo target/ trees: workspace root, optional worktrees, optional nested crates/*/target/.
//
// Default run is dry-run (lists candidates; does not delete or run cargo clean).
// Destructive steps require VOX_CLEAN_EXECUTE=1.
//
// Env:
//   VOX_REPO_ROOT — repo root (default "." relative to process CWD when you run vox; set explicitly when needed).
//   VOX_CLEAN_EXECUTE=1 — run cargo clean at repo root and remove discovered target/ dirs.
//   VOX_WORKTREE_BASE — worktree parent directory (default .claude/worktrees).
//   VOX_CLEAN_NESTED_CRATE_TARGETS=1 — also scan crates/*/target/ (dry-run lists; deletes only with VOX_CLEAN_EXECUTE=1).
//
// See: docs/src/architecture/where-things-live.md (Rust workspace row) for CARGO_TARGET_DIR guidance.

fn resolve_repo() to str {
    let opt = std.env.get("VOX_REPO_ROOT");
    if opt.is_some() {
        return opt.unwrap();
    }
    return ".";
}

fn env_flag(name: str) to bool {
    let opt = std.env.get(name);
    if opt.is_some() {
        return opt.unwrap() == "1";
    }
    return false;
}

fn norm(p: str) to str {
    return p.replace("\\", "/");
}

fn collect_glob(pattern: str) to list[str] {
    let g = std.fs.glob(pattern);
    if g.is_err() {
        print("  [warn] glob failed for pattern: " + pattern);
        return [];
    }
    return g.unwrap();
}

fn is_target_dir(p: str) to bool {
    if not std.fs.is_dir(p) {
        return false;
    }
    return norm(p).ends_with("/target");
}

fn worktree_target_pattern(base: str) to str {
    let b = norm(base);
    if b.ends_with("/") {
        return b + "*/target";
    }
    return b + "/*/target";
}

fn nested_crate_target_pattern(repo: str) to str {
    let r = norm(repo);
    if r.ends_with("/") {
        return r + "crates/*/target";
    }
    return r + "/crates/*/target";
}

fn main() {
    let repo = resolve_repo();
    let execute = env_flag("VOX_CLEAN_EXECUTE");
    let nested = env_flag("VOX_CLEAN_NESTED_CRATE_TARGETS");

    let wt_opt = std.env.get("VOX_WORKTREE_BASE");
    let mut wt_base = ".claude/worktrees";
    if wt_opt.is_some() {
        wt_base = wt_opt.unwrap();
    }

    print("=== Vox build artifact cleanup ===");
    print("Repo root: " + repo);
    if execute {
        print("Mode: EXECUTE (VOX_CLEAN_EXECUTE=1)");
    } else {
        print("Mode: DRY-RUN (no deletes, no `cargo clean`)");
    }
    print("");

    print("--- Workspace `cargo clean` ---");
    if execute {
        let code_res = std.process.run_ex("cargo", ["clean"], repo, []);
        match code_res {
            Ok(code) => {
                if code == 0 {
                    print("  `cargo clean` finished with exit 0.");
                } else {
                    print("  [warn] `cargo clean` exited with code " + str(code));
                }
            }
            Error(e) => print("  [err] `cargo clean` failed to spawn: " + e),
        }
    } else {
        print("  Skipped. Set VOX_CLEAN_EXECUTE=1 to run `cargo clean` in the repo root above.");
    }
    print("");

    print("--- Worktree target/ directories under " + wt_base + " ---");
    if not std.fs.exists(wt_base) {
        print("  (base missing; nothing to scan)");
    } else {
        let pattern = worktree_target_pattern(wt_base);
        let hits = collect_glob(pattern);
        let mut n = 0;
        for p in hits {
            if is_target_dir(p) {
                n = n + 1;
                let pn = norm(p);
                if execute {
                    let rm = std.fs.remove_dir_all(p);
                    match rm {
                        Ok(_) => print("  removed: " + pn)
                        Error(e) => {
                            print("  [err] remove_dir_all");
                            print(pn);
                            print(e);
                        }
                    }
                } else {
                    print("  would remove: " + pn);
                }
            }
        }
        if n == 0 {
            print("  (no */target matches under worktree base)");
        } else if not execute {
            print("  Total candidates: " + str(n) + " (dry-run only)");
        }
    }
    print("");

    print("--- Nested crates/*/target/ (excluded-workspace crates) ---");
    if nested {
        let pattern = nested_crate_target_pattern(repo);
        let hits = collect_glob(pattern);
        let mut n = 0;
        for p in hits {
            if is_target_dir(p) {
                n = n + 1;
                let pn = norm(p);
                if execute {
                    let rm = std.fs.remove_dir_all(p);
                    match rm {
                        Ok(_) => print("  removed: " + pn)
                        Error(e) => {
                            print("  [err] remove_dir_all");
                            print(pn);
                            print(e);
                        }
                    }
                } else {
                    print("  would remove: " + pn);
                }
            }
        }
        if n == 0 {
            print("  (no nested crate target/ trees found)");
        } else if not execute {
            print("  Total candidates: " + str(n) + " (dry-run; set VOX_CLEAN_EXECUTE=1 to delete)");
        }
    } else {
        print("  Skipped. Set VOX_CLEAN_NESTED_CRATE_TARGETS=1 to scan crates/*/target/.");
    }
    print("");

    print("Notes:");
    print("  - Cargo never garbage-collects stale rlibs under target/debug/deps; periodic `cargo clean` is normal.");
    print("  - Root Cargo.toml [profile.dev] rules reduce rlib bloat; see comments in Cargo.toml.");
    print("  - Do not rely on this script for ~/.cargo/registry sizing; that cache is shared and usually left alone.");
}
