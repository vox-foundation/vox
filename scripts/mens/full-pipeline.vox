// vox:caps fs subprocess env

fn main() {
    print("  ╔══════════════════════════════════════════════════╗")
    print("  ║     VoxMens — Automated Training Pipeline        ║")
    print("  ╚══════════════════════════════════════════════════╝")
    print("")

    let mut domain = "vox-lang"
    let domain_env = env.get("VOX_MENS_DOMAIN")
    if domain_env isnt null {
        domain = domain_env.unwrap()
    }

    let mut epochs = "3"
    let epochs_env = env.get("VOX_MENS_EPOCHS")
    if epochs_env isnt null {
        epochs = epochs_env.unwrap()
    }

    let device = "cuda"
    let preset = "qwen_4080_16g"

    let skip_mix_env = env.get("VOX_MENS_SKIP_MIX")
    let skip_eval_env = env.get("VOX_MENS_SKIP_EVAL")
    let background_env = env.get("VOX_MENS_BACKGROUND")

    let mut skip_mix = false
    if skip_mix_env isnt null {
        let val = skip_mix_env.unwrap()
        if val == "1" { skip_mix = true }
        if val == "true" { skip_mix = true }
    }

    let mut skip_eval = false
    if skip_eval_env isnt null {
        let val = skip_eval_env.unwrap()
        if val == "1" { skip_eval = true }
        if val == "true" { skip_eval = true }
    }

    let mut background = false
    if background_env isnt null {
        let val = background_env.unwrap()
        if val == "1" { background = true }
        if val == "true" { background = true }
    }

    let force_env = env.get("VOX_MENS_FORCE_TRAIN")
    let mut force_train = false
    if force_env isnt null {
        let val = force_env.unwrap()
        if val == "1" { force_train = true }
        if val == "true" { force_train = true }
    }

    print("  Domain:   " + domain)
    print("  Epochs:   " + epochs)
    print("  Device:   " + device)
    print("  Preset:   " + preset)
    
    // Step 1: Corpus Mix
    if skip_mix {
        print("Step 1/5: Skipping corpus mix (VOX_MENS_SKIP_MIX set).")
    } else {
        print("Step 1/5: Running corpus mix for domain '" + domain + "'...")
        
        print("  Running primary mix (mix.yaml → target/dogfood/train_mixed.jsonl)...")
        let primary_mix = process.run("cargo", ["run", "-p", "vox-cli", "--", "mens", "corpus", "mix", "--config", "mens/config/mix.yaml"])
        if primary_mix isnt null {
            let res = primary_mix.unwrap()
            if res.code == 0 {
                print("  ✓ Primary mix complete.")
            } else {
                print("  ✗ Primary mix failed.")
                return null
            }
        }
        
        let mut domain_config = "mens/config/mix-" + domain + ".yaml"
        if domain == "rust-expert" {
            domain_config = "mens/config/mix-rust.yaml"
        }
        
        print("  Running domain mix (" + domain_config + ")...")
        let domain_mix = process.run("cargo", ["run", "-p", "vox-cli", "--", "mens", "corpus", "mix", "--config", domain_config])
        if domain_mix isnt null {
            let res = domain_mix.unwrap()
            if res.code == 0 {
                print("  ✓ Domain mix complete.")
            } else {
                print("  ⚠ Domain mix failed or not found (using primary mix output).")
            }
        }
        
        // Diversity check
        let primary_corpus = "target/dogfood/validated_mixed.jsonl"
        print("  Recording diversity metrics (Domain: " + domain + ")...")
        let diversity = process.run("cargo", ["run", "-p", "vox-cli", "--", "mens", "corpus", "diversity-check", "--input", primary_corpus, "--domain", domain])
        if diversity isnt null {
            let res = diversity.unwrap()
            if res.code == 0 {
                print("  ✓ Diversity metrics recording attempt finished.")
            } else {
                print("  ⚠ Diversity check returned warning/alarm.")
            }
        }
    }

    // Step 2: Pre-flight eval gate
    // Default policy file is mens/config/eval-gates.yaml — DO NOT pass `--policy warn`,
    // that resolves as a non-existent path and the gate silently no-ops (Ok(0)).
    // Set VOX_MENS_FORCE_TRAIN=1 to proceed past a failing gate (dev iteration only).
    if skip_eval {
        print("Step 2/5: Skipping pre-flight eval (VOX_MENS_SKIP_EVAL set).")
    } else {
        print("Step 2/5: Running pre-flight eval gate (mens/config/eval-gates.yaml)...")
        let eval_run = process.run("cargo", ["run", "-p", "vox-cli", "--", "mens", "eval-gate", "--run-dir", "mens/runs/latest"])
        if eval_run isnt null {
            let res = eval_run.unwrap()
            if res.code == 0 {
                print("  ✓ Eval gate passed.")
            } else {
                if force_train {
                    print("  ⚠ Eval gate FAILED but VOX_MENS_FORCE_TRAIN=1 — proceeding anyway.")
                } else {
                    print("  ✗ Eval gate FAILED (blocking). Inspect mens/runs/latest/eval_results.json.")
                    print("    Override for dev iteration: VOX_MENS_FORCE_TRAIN=1")
                    return null
                }
            }
        }
    }

    // Step 3: Training
    print("Step 3/5: Launching training...")
    let mut train_args = [
        "run", "-p", "vox-cli", "--",
        "mens", "train",
        "--backend", "qlora",
        "--tokenizer", "hf",
        "--device", device,
        "--preset", preset,
        "--domain", domain,
        "--epochs", epochs,
        "--data-dir", "target/dogfood",
        "--output-dir", "mens/runs/latest",
        "--seed", "42",
        "--qlora-ce-last-k", "64",
        "--validation-split-ratio", "0.05",
        "--force-restart"
    ]

    if background {
        print("  Spawning background process via process.run (acting as spawn for now)...")
        let train_proc = process.run("cargo", train_args)
        if train_proc isnt null {
            print("  ✓ Training process spawned in background.")
        } else {
            print("  ✗ Failed to spawn background process.")
        }
    } else {
        print("  Running training in foreground...")
        let train_proc = process.run("cargo", train_args)
        if train_proc isnt null {
            let res = train_proc.unwrap()
            if res.code == 0 {
                print("  ✓ Training complete.")
            } else {
                print("  ✗ Training failed with exit code: " + str(res.code))
                return null
            }
        } else {
            print("  ✗ Failed to run training process.")
            return null
        }
    }

    if background == false {
        // Step 4: Refresh eval_results.json in the run directory.
        // The QLoRA trainer does NOT write eval_results.json (only the legacy
        // mens-dei+gpu path does). Without this step, Step 5's eval_local gate
        // would read a stale file left by the previous pipeline run — or find
        // nothing at all on a first run. We evaluate the same train.jsonl the
        // trainer consumed and write fresh results directly into the run dir.
        // Non-blocking: a corpus eval failure should not abort a successful training run.
        print("Step 4/5: Refreshing corpus eval metrics...")
        let corpus_eval = process.run("cargo", ["run", "-p", "vox-cli", "--", "mens", "corpus", "eval", "target/dogfood/train.jsonl", "--output", "mens/runs/latest/eval_results.json", "--print-summary"])
        if corpus_eval isnt null {
            let res = corpus_eval.unwrap()
            if res.code == 0 {
                print("  ✓ eval_results.json refreshed.")
            } else {
                print("  ⚠ Corpus eval failed — Step 4 gate will use prior eval_results.json (may be stale).")
            }
        }

        // Post-training verification doubles as the A2A run receipt.
        // Uses eval-gates-post-train.yaml: pass_at_k and review_recurrence are
        // warn-only because those require explicit eval-local + review pipeline
        // steps after training. Blocking gates cover trainer-written artifacts:
        // training_manifest.json, telemetry.jsonl, eval_results.json.
        print("Step 5/5: Post-training verification (run receipt)...")
        let post_gate = process.run("cargo", ["run", "-p", "vox-cli", "--", "mens", "eval-gate", "--run-dir", "mens/runs/latest", "--policy", "mens/config/eval-gates-post-train.yaml"])
        if post_gate isnt null {
            let res = post_gate.unwrap()
            if res.code == 0 {
                print("  ✓ Post-training gate passed — run artifacts are valid.")
            } else {
                if force_train {
                    print("  ⚠ Post-training gate FAILED but VOX_MENS_FORCE_TRAIN=1 — receipt marked degraded.")
                } else {
                    print("  ✗ Post-training gate FAILED — run is NOT servable.")
                    print("    Inspect: mens/runs/latest/eval_results.json")
                    print("    Override for dev iteration: VOX_MENS_FORCE_TRAIN=1")
                    return null
                }
            }
        }
        print("  Pipeline complete.")
        print("  Next steps (required before serving):")
        print("    vox mens eval-local --model mens/runs/latest --bench <bench_dir>")
        print("    vox mens eval-gate --run-dir mens/runs/latest  (full policy, promotes run)")
    }
}
