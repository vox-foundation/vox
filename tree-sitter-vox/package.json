{
  "name": "tree-sitter-vox",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Vox programming language",
  "main": "bindings/node",
  "keywords": ["parser", "tree-sitter", "vox"],
  "license": "MIT",
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.0"
  },
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "highlight": "tree-sitter highlight"
  },
  "tree-sitter": [
    {
      "scope": "source.vox",
      "file-types": ["vox"],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm"
    }
  ]
}
