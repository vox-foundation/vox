// vox:caps fs env process clavis
import fs;
import env;
import process;
import clavis;

fn main() {
    print("Testing Interpreter Builtins...")
    
    // Env
    let path = env.get("PATH")
    if path.is_some() {
        print("✅ env.get working")
    } else {
        print("❌ env.get failed")
    }
    
    // FS
    let test_file = "scratch/test_io.txt"
    fs.write_file(test_file, "hello vox")
    let content = fs.read_file(test_file)
    if content is "hello vox" {
        print("✅ fs.read/write working")
    } else {
        print("❌ fs.read/write failed: " + content)
    }
    
    // Process
    let res = process.run("cmd", ["/c", "echo vox-spawn"])
    if res.code is 0 and res.stdout.contains("vox-spawn") {
        print("✅ process.run working")
    } else {
        print("❌ process.run failed: " + str(res.code))
    }
    
    // Clavis (best effort, may return null if no keys set)
    let secret = clavis.resolve("VOX_DB_TOKEN")
    if secret isnt null {
        print("✅ clavis.resolve working (found secret)")
    } else {
        print("ℹ️ clavis.resolve returned null (expected if VOX_DB_TOKEN is unset)")
    }
    
    print("All tests complete.")
}
