{
  "name": "vox-lang",
  "displayName": "Vox Language",
  "description": "Vox language support: LSP, MCP workspace (chat, Oratio speech, snapshots), web artifact import hints (routes.manifest / vox-client), and AI-assisted editing.",
  "version": "0.2.1",
  "publisher": "vox-lang",
  "license": "Apache-2.0",
  "keywords": [
    "vox",
    "mcp",
    "model-context-protocol",
    "oratio",
    "speech",
    "speech-to-code",
    "lsp",
    "ai"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Machine Learning"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:**/routes.manifest.ts",
    "workspaceContains:**/*.vox",
    "onCommand:vox.inlineEdit.accept",
    "onCommand:vox.inlineEdit.escapeReject",
    "onCommand:vox.inlineEdit.regenerate",
    "onCommand:vox.inlineEdit.reject"
  ],
  "contributes": {
    "languages": [
      {
        "id": "vox",
        "aliases": [
          "Vox",
          "vox"
        ],
        "extensions": [
          ".vox"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/vox-icon.png",
          "dark": "./icons/vox-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "vox",
        "scopeName": "source.vox",
        "path": "./syntaxes/vox.tmLanguage.json"
      },
      {
        "scopeName": "markdown.vox.codeblock",
        "path": "./syntaxes/markdown-injection.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.vox": "vox"
        }
      }
    ],
    "configuration": {
      "title": "Vox AI settings",
      "properties": {
        "vox.inlineAI.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Ghost Text autocomplete and Inline Edits."
        },
        "vox.inlineAI.debounceMs": {
          "type": "number",
          "default": 600,
          "description": "Delay in ms before analyzing code for ghost text."
        },
        "vox.composer.autoApply": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply Composer changes instead of reviewing them."
        },
        "vox.agent.defaultMode": {
          "type": "string",
          "enum": [
            "chat",
            "plan",
            "debug",
            "auto"
          ],
          "default": "auto",
          "description": "Default agent mode."
        },
        "vox.vcs.showSnapshotBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the Snapshots tree under the Vox sidebar. VCS commands (undo/redo, snapshot list, …) stay available when this is off."
        },
        "vox.gamify.showHud": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Companion gamification HUD."
        },
        "vox.visualizer.protocol": {
          "type": "string",
          "enum": [
            "iframe",
            "sdui_native"
          ],
          "default": "sdui_native",
          "description": "Protocol used to render the visualizer"
        },
        "vox.visualizer.autoDiscovery": {
          "type": "boolean",
          "default": true,
          "description": "Automatically discover new Vox language features from the server-driven UI."
        },
        "vox.ai.model": {
          "type": "string",
          "default": "gemini-2.0-flash-lite",
          "description": "Active AI Model"
        },
        "vox.lsp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the vox-lsp binary."
        },
        "vox.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Vox Language Server."
        },
        "vox.webArtifacts.diagnosticsEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Validate `./` imports from `routes.manifest.ts` / `vox-client.ts` against files on disk (parity with `vox build` output layout)."
        },
        "vox.mcp.serverPath": {
          "type": "string",
          "default": "vox",
          "description": "Executable or path to the Vox CLI used for MCP stdio (`vox mcp`)."
        },
        "vox.mcp.debugPayloads": {
          "type": "boolean",
          "default": false,
          "description": "Log MCP tool arguments and truncated results to the Vox output channel. Trust / client disclosure SSOT: docs/src/architecture/telemetry-client-disclosure-ssot.md"
        },
        "vox.mcp.warnOnMissingTools": {
          "type": "boolean",
          "default": true,
          "description": "After connect, log if runtime list_tools is missing tools expected by the workspace UI (see MCP_EXTENSION_EXPECTED_TOOLS in generated registry)."
        },
        "vox.mcp.shadowPlanAdequacyToast": {
          "type": "boolean",
          "default": true,
          "description": "When the server returns shadow plan-adequacy and marks the plan as too thin, show an editor notification (details always go to the Vox output channel)."
        },
        "vox.models.byok.anthropic": {
          "type": "string",
          "default": "",
          "description": "BYOK API Key for Anthropic."
        },
        "vox.models.byok.openai": {
          "type": "string",
          "default": "",
          "description": "BYOK API Key for OpenAI."
        },
        "vox.attention.panelVisible": {
          "type": "boolean",
          "default": true,
          "description": "Show the Attention Budget and Tracking panel in the sidebar."
        },
        "vox.attention.notificationLevel": {
          "type": "string",
          "enum": ["none", "high", "critical"],
          "default": "high",
          "description": "Verbosity level for Vox attention interruption notifications/toasts."
        },
        "vox.attention.pollIntervalMs": {
          "type": "number",
          "default": 10000,
          "description": "Client polling interval for attention metrics."
        }
      }
    },
    "commands": [
      {
        "command": "vox.build",
        "title": "Vox: Build Current File"
      },
      {
        "command": "vox.run",
        "title": "Vox: Run Current Project"
      },
      {
        "command": "vox.restartLsp",
        "title": "Vox: Restart Language Server"
      },
      {
        "command": "vox.focusSidebar",
        "title": "Vox: Open Chat"
      },
      {
        "command": "vox.pickModel",
        "title": "Vox: Select AI Model"
      },
      {
        "command": "vox.openVisualEditor",
        "title": "Vox: Open Visual Editor",
        "category": "Vox"
      },
      {
        "command": "vox.snapshotRefresh",
        "title": "Vox: Refresh Snapshots",
        "category": "Vox"
      },
      {
        "command": "vox.snapshotViewDiff",
        "title": "Vox: View Snapshot Diff",
        "category": "Vox"
      },
      {
        "command": "vox.snapshotRestore",
        "title": "Vox: Restore Snapshot",
        "category": "Vox"
      },
      {
        "command": "vox.refreshStatus",
        "title": "Vox: Refresh Provider Status",
        "category": "Vox"
      },
      {
        "command": "vox.inlineEdit",
        "title": "Vox: Inline Edit (Ask)"
      },
      {
        "command": "vox.inlineExplain",
        "title": "Vox: Explain Code"
      },
      {
        "command": "vox.inlineFix",
        "title": "Vox: Fix Errors"
      },
      {
        "command": "vox.snapshotList",
        "title": "Vox: View Snapshots"
      },
      {
        "command": "vox.undo",
        "title": "Vox: Undo (VCS)"
      },
      {
        "command": "vox.redo",
        "title": "Vox: Redo (VCS)"
      },
      {
        "command": "vox.plan",
        "title": "Vox: Planning Mode — Generate PLAN.md"
      },
      {
        "command": "vox.journey.canonicalChecklist",
        "title": "Vox: Open canonical MENS dev journey (from Codex)",
        "category": "Vox"
      },
      {
        "command": "vox.debugMode",
        "title": "Vox: Enable Agent Debug Mode"
      },
      {
        "command": "vox.rebalance",
        "title": "Vox: Rebalance Agents"
      },
      {
        "command": "vox.agent.spawn",
        "title": "Vox: Spawn Orchestrator Agent",
        "category": "Vox"
      },
      {
        "command": "vox.oratio.transcribeFile",
        "title": "Vox: Oratio — Transcribe audio file",
        "category": "Vox"
      },
      {
        "command": "vox.oratio.speechToCodeFile",
        "title": "Vox: Oratio — Speech to code (audio file)",
        "category": "Vox"
      },
      {
        "command": "vox.oratio.voiceCaptureTranscribe",
        "title": "Vox: Oratio — Voice capture → transcribe",
        "category": "Vox"
      },
      {
        "command": "vox.oratio.voiceCaptureSpeechToCode",
        "title": "Vox: Oratio — Voice capture → speech to code",
        "category": "Vox"
      },
      {
        "command": "vox.commandPalette",
        "title": "Vox: Command Entry (Dynamic)"
      }
    ],
    "keybindings": [
      {
        "command": "vox.inlineEdit",
        "key": "ctrl+k",
        "mac": "cmd+k",
        "when": "editorTextFocus"
      },
      {
        "command": "vox.plan",
        "key": "ctrl+shift+p ctrl+p",
        "mac": "cmd+shift+p cmd+p"
      },
      {
        "command": "vox.inlineEdit.accept",
        "key": "tab",
        "when": "vox.inlineEditActive"
      },
      {
        "command": "vox.inlineEdit.escapeReject",
        "key": "escape",
        "when": "vox.inlineEditActive || editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vox.inlineEdit",
          "group": "vox@1"
        },
        {
          "command": "vox.inlineExplain",
          "group": "vox@2"
        },
        {
          "command": "vox.inlineFix",
          "group": "vox@3"
        },
        {
          "command": "vox.plan",
          "group": "vox@4"
        }
      ],
      "explorer/context": [
        {
          "command": "vox.oratio.transcribeFile",
          "group": "vox_oratio@1",
          "when": "resourceFilename =~ /\\.(wav|mp3|flac|ogg|m4a|webm)$/i"
        },
        {
          "command": "vox.oratio.speechToCodeFile",
          "group": "vox_oratio@2",
          "when": "resourceFilename =~ /\\.(wav|mp3|flac|ogg|m4a|webm)$/i"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vox-sidebar",
          "title": "Vox",
          "icon": "$(zap)"
        }
      ]
    },
    "views": {
      "vox-sidebar": [
        {
          "type": "webview",
          "id": "vox-sidebar.chat",
          "name": "Vox Workspace",
          "icon": "$(zap)"
        },
        {
          "id": "vox-snapshots",
          "name": "Snapshots",
          "when": "config.vox.vcs.showSnapshotBar",
          "icon": "$(git-commit)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "generate:mcp-registry": "node ./scripts/generate-mcp-tool-registry.mjs",
    "check:mcp-parity": "node ./scripts/check-mcp-tool-parity.mjs",
    "check:activation-parity": "node ./scripts/check-activation-parity.mjs",
    "build:css": "tailwindcss -i ./webview-ui/src/input.css -o ./out/webview.css --minify",
    "watch:css": "tailwindcss -i ./webview-ui/src/input.css -o ./out/webview.css --watch",
    "compile": "npm run generate:mcp-registry && npm run check:mcp-parity && npm run build:css && tsc -p ./ && node esbuild.js && node ./scripts/smoke-host-messages.mjs && node ./scripts/smoke-webview-render.mjs",
    "watch": "npm run build:css && npx concurrently \"npm run watch:css\" \"tsc -watch -p ./\"",
    "lint": "eslint src webview-ui/src --max-warnings 100",
    "package": "vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.27.3",
    "eslint": "^10.1.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "vscode-languageclient": "^9.0.1",
    "zod": "^3.25.76"
  }
}
