{
  "fileTypes": [],
  "injectionSelector": "L:text.html.markdown, L:text.html.markdown.source",
  "scopeName": "markdown.vox.codeblock",
  "patterns": [
    {
      "include": "#vox-code-block"
    }
  ],
  "repository": {
    "vox-code-block": {
      "begin": "(^|\\G)(\\s*)(`{3,}|~{3,})\\s*(?i:(voxcode|vox))\\s*$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.markdown" },
        "4": { "name": "fenced_code.block.language.markdown" }
      },
      "end": "(^|\\G)(\\s*)(\\3|~{3,})\\s*$",
      "endCaptures": {
        "3": { "name": "punctuation.definition.markdown" }
      },
      "contentName": "meta.embedded.block.vox",
      "patterns": [
        {
          "include": "source.vox"
        }
      ]
    }
  }
}
