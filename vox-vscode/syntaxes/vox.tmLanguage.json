{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vox",
  "comment": "Vocabulary contract: tree-sitter-vox/GRAMMAR_SSOT.md",
  "scopeName": "source.vox",
  "patterns": [
    { "include": "#comments" },
    { "include": "#decorators" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#jsx" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.vox",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.vox",
          "match": "//.*$"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "entity.name.function.decorator.vox",
          "match": "@(table|query|mutation|action|collection|index|vector_index|search_index|layout|loading|not_found|error_boundary|test|fixture|mock|trace|health|metric|scheduled|mcp\\.(tool|resource)|agent_def|skill|v0|py_import|deprecated|pure|require|theme|keyframes|server)\\b"
        },
        {
          "name": "entity.name.function.decorator.args.vox",
          "match": "@[a-zA-Z_][a-zA-Z0-9_.]*(?=\\()"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vox",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.vox",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.vox",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.vox",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.vox",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.optional-chain.vox",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.logical.vox",
          "match": "\\b(and|or|not|isnt)\\b"
        },
        {
          "name": "keyword.operator.comparison.vox",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.vox",
          "match": "(=|\\+=|-=|\\*=|/=|%=)"
        },
        {
          "name": "keyword.operator.arithmetic.vox",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.range.vox",
          "match": "(\\.\\.=|\\.\\.)"
        },
        {
          "name": "keyword.operator.misc.vox",
          "match": "(\\.|,|:|;|->|\\?|!|\\|)"
        },
        {
          "name": "storage.type.vox",
          "match": "\\b(fn|component|type|actor|workflow|activity|struct|enum|trait|impl|message|state|routes|on|to|from|import|use|str|int|float|bool|Unit|Result|Option|List|Map|Id|island|style)\\b"
        },
        {
          "name": "storage.modifier.vox",
          "match": "\\b(pub|const|async|mut)\\b"
        },
        {
          "name": "keyword.control.vox",
          "match": "\\b(if|else|for|while|match|return|as|try|catch|throw|await|with|spawn|yield)\\b"
        },
        {
          "name": "keyword.other.http-method.vox",
          "match": "\\b(get|post|put|delete)\\b"
        },
        {
          "name": "keyword.operator.vox",
          "match": "\\b(assert)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.vox",
          "match": "\\b(int|str|bool|Unit|Element)\\b"
        },
        {
          "name": "support.type.collection.vox",
          "match": "\\b(List|Map|Set|Result|Option|Id)\\b"
        },
        {
          "name": "entity.name.type.vox",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.vox",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.none.vox",
          "match": "\\b(None|Ok|Err|Some)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.vox",
          "match": "->"
        },
        {
          "name": "keyword.operator.pipe.vox",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.comparison.vox",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.vox",
          "match": "(=|\\+=|-=)"
        },
        {
          "name": "keyword.operator.arithmetic.vox",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.try.vox",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.optional-chain.vox",
          "match": "\\?\\."
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(fn|component|test|workflow|activity)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.vox" },
            "2": { "name": "entity.name.function.vox" }
          }
        },
        {
          "name": "entity.name.function.call.vox",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "jsx": {
      "patterns": [
        {
          "name": "entity.name.tag.vox",
          "match": "(?<=<\\s*/?)\\s*[a-zA-Z][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.other.attribute-name.vox",
          "match": "\\b[a-z][a-zA-Z0-9_]*(?=\\s*=)"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.vox",
          "match": "(?<=let\\s+(?:mut\\s+)?)[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    }
  }
}
