{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vox",
  "scopeName": "source.vox",
  "patterns": [
    { "include": "#comments" },
    { "include": "#decorators" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#jsx" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.vox",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.vox",
          "match": "//.*$"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "entity.name.function.decorator.vox",
          "match": "@(mcp\\.tool|mcp\\.resource|table|server|component|test|query|mutation|action|v0|skill|agent_def|deprecated|pure|require|index|storage)\\b"
        },
        {
          "name": "entity.name.function.decorator.vox",
          "match": "@[a-zA-Z_][a-zA-Z0-9_.]*"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vox",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.vox",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.vox",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.vox",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.vox",
          "match": "\\b(if|else|for|while|match|in|and|or|not|ret|with|import)\\b"
        },
        {
          "name": "keyword.declaration.vox",
          "match": "\\b(fn|let|mut|type|actor|workflow|activity|message|http|routes|style)\\b"
        },
        {
          "name": "keyword.other.vox",
          "match": "\\b(to|on|is|spawn|state|bind)\\b"
        },
        {
          "name": "keyword.operator.vox",
          "match": "\\b(assert)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.vox",
          "match": "\\b(int|str|bool|Unit|Element)\\b"
        },
        {
          "name": "support.type.collection.vox",
          "match": "\\b(List|Map|Set|Result|Option|Id)\\b"
        },
        {
          "name": "entity.name.type.vox",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.vox",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.none.vox",
          "match": "\\b(None|Ok|Err|Some)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.vox",
          "match": "->"
        },
        {
          "name": "keyword.operator.pipe.vox",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.comparison.vox",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.vox",
          "match": "(=|\\+=|-=)"
        },
        {
          "name": "keyword.operator.arithmetic.vox",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.try.vox",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.optional-chain.vox",
          "match": "\\?\\."
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.vox",
          "match": "(?<=fn\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.name.function.call.vox",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "jsx": {
      "patterns": [
        {
          "name": "entity.name.tag.vox",
          "match": "(?<=<\\s*/?)\\s*[a-zA-Z][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.other.attribute-name.vox",
          "match": "\\b[a-z][a-zA-Z0-9_]*(?=\\s*=)"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.vox",
          "match": "(?<=let\\s+(?:mut\\s+)?)[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    }
  }
}
