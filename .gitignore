/jobs.json
/runs.json

# Generated test fixture snapshots (re-created by build)
crates/vox-populi/tests/fixtures/
docs/book/

# Large model and data artifacts
*.safetensors
*.jsonl

# Corpus mix reports — machine-specific absolute paths; regenerated by `vox mens corpus mix`
mens/data/*.mix_report.json

# All training run directories are machine-local artifacts — never commit run artifacts.
# Named runs (agent_*, bg_*, v1, qwen35_*, etc.), logs, latest/, and all
# pipeline-generated artifacts (training_manifest.json, telemetry.jsonl,
# eval_results.json, gate_receipt.json, eval_local_report.json,
# benchmark_passatk.json, review_metrics.json, benchmark_gate_eval.json,
# training-preflight.json, checkpoint_state.json, etc.) are covered by this rule.
mens/runs/

# Repo-root only: renamed `target` trees when deletes fail on locked binaries (e.g. Windows).
/target*.stale-*/

# Session artifacts — explicit patterns so *.txt negation doesn't hide these
/check*.txt
/check*.log
/cargo_check_output.txt
/check_output.txt
/check_errors.txt
/check_mens_errors*.txt
/cargo_errors*.txt
/train_out*.txt
/run*.txt
/build_log*.txt

# Root-level stale build/debug artifacts (never commit)
/check.log
/parser_errors.txt
/spec.rs.bak
/*.diff
/*.patch
/update.diff

