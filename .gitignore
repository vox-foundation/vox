**/*.rs.bk
Cargo.lock

# Node
**/node_modules/
**/out/
node_modules/
dist/
dist1/
.env

# Local TOESTUB / audit outputs (do not commit large JSON baselines)
/artifacts/

# Tests and Scratch Output
test_output*.txt
bundle_*.txt
*.log


# Editor / IDE artifacts (keep shared `settings.json` for terminal PATH / CUDA)
.vscode/*
!.vscode/settings.json
.idea/
.cursor/plans/

# Python (local tooling under scripts/)
scripts/.venv/
crates/vox-py/.venv/
.mypy_cache/
*.swp
*~

# CodeRabbit CLI worktrees and state (`vox review coderabbit`, `--features coderabbit`)
.coderabbit/

# Dist / JS Islands
islands/
crates/*/pkg/
dist/app/node_modules/

# Populi / AI Models / Data
populi/runs/
populi/data/*.jsonl
.vox-research-data/
.vox/cache/
*.db-wal
*.db-shm


# Jujutsu VCS
.jj/

# Scratch files
cargo-out.txt
test_all.txt
*.bak
*.orig
crates/*/target/
crates/*/target_*/

# Root-level scratch/debug output (should never be committed)
/*.txt
/*.err
/*.bat
/*.py
/*.jsonl
/*_head.rs
/*_scratch*.rs
/dump.txt
/sql_dump.txt
/raw_err*.json
/check_err*.json
/clippy_output.json
/pm_errors.json

# Generated test fixture snapshots (re-created by build)
crates/vox-populi/tests/fixtures/
crates/vox-mesh/tests/*.sample.json
docs/book/

# Large model and data artifacts
*.safetensors
*.jsonl
mens/runs/latest/training_manifest.json
mens/runs/latest/checkpoint_state.json
mens/runs/qwen35_qlora_smoke35_v4/checkpoint_state.json
