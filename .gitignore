.opencode/
vox-agent.json
vox-schema.json
stub_check_results2.json


# Jujutsu VCS
.jj/

# Local agent/tooling scratch under repo root (prefer OS temp for secrets)
/tmp/

# Scratch files
cargo-out.txt
test_all.txt
*.bak
*.orig
crates/*/target/
crates/*/target_*/

# Root-level scratch/debug output (should never be committed)
/*.txt
/*.err
/*.bat
/*.py
/*.jsonl
/*_head.rs
/*_scratch*.rs
/dump.txt
/sql_dump.txt
/raw_err*.json
/check_err*.json
/clippy_output.json
/pm_errors.json

# Generated test fixture snapshots (re-created by build)
crates/vox-populi/tests/fixtures/
docs/book/

