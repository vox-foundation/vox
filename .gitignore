# Rust
target/
target_*/
# Side `CARGO_TARGET_DIR=*` trees (mostly repo root); global `target-*/` also covers nested mistakes.
target-*/
.cargo-targets/
**/*.rs.bk
Cargo.lock

# Node
**/node_modules/
**/out/
node_modules/
dist/
dist1/
.env

# Local TOESTUB / audit outputs (do not commit large JSON baselines)
/artifacts/

# Tests and Scratch Output
test_output*.txt
bundle_*.txt
*.log


# Editor / IDE artifacts (keep shared `settings.json` for terminal PATH / CUDA)
.vscode/*
!.vscode/settings.json
.idea/
.cursor/plans/

# Python (local tooling under scripts/)
scripts/.venv/
crates/vox-py/.venv/
.mypy_cache/
*.swp
*~

# CodeRabbit CLI worktrees and state (`vox review coderabbit`, `--features coderabbit`)
.coderabbit/

# Dist / JS Islands
islands/
crates/*/pkg/
dist/app/node_modules/

# Populi / AI Models / Data
populi/runs/
populi/data/*.jsonl
.vox-research-data/
.vox/cache/
*.db-wal
