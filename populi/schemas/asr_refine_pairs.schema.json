{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox.dev/schemas/asr_refine_pairs.json",
  "title": "ASR refinement pair (noisy transcript → corrected)",
  "type": "object",
  "required": ["noisy_text", "corrected_text"],
  "additionalProperties": true,
  "properties": {
    "noisy_text": { "type": "string", "description": "Raw or noisy ASR output" },
    "corrected_text": { "type": "string", "description": "Human- or model-corrected transcript" },
    "category": { "type": "string" },
    "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
    "source": { "type": "string", "description": "Provenance, e.g. synthetic" }
  }
}
