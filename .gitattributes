# Default: let Git classify text vs binary; normalize line endings per rules below.
* text=auto

# Bash must stay LF (Windows Git Bash / CI).
*.sh text eol=lf

# PowerShell: CRLF on checkout for Windows editors (repo may still store normalized per Git version).
*.ps1 text eol=crlf

# Source, docs, and configs: LF everywhere for Linux CI and cross-platform diffs.
*.rs text eol=lf
*.toml text eol=lf
*.lock text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.mts text eol=lf
*.py text eol=lf
*.vox text eol=lf
*.gd text eol=lf
*.css text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Book/docs under docs/src (explicit; also covered by *.md).
docs/src/**/*.md text eol=lf

# Windows batch (if present): native CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Common binaries — do not touch line endings or diff as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.wasm binary
*.parquet binary
*.npy binary
*.npz binary
*.pt binary
*.pth binary
*.onnx binary
*.safetensors binary
*.bin binary
