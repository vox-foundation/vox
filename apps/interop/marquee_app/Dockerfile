# Generated by Vox — marquee_app OCI image
# This Dockerfile expects a pre-built 'build/' directory in the context.
# Build on host: pnpm build

FROM nginx:1.27-alpine AS serve

LABEL org.opencontainers.image.source="https://github.com/owner/vox"
LABEL org.opencontainers.image.description="Vox marquee application"
LABEL org.opencontainers.image.licenses="Apache-2.0"

WORKDIR /usr/share/nginx/html

# Copy built assets from host build directory
COPY build/ .

# SPA routing: fall back to index.html for client-side routes
RUN printf 'server {\n\
    listen 80;\n\
    root /usr/share/nginx/html;\n\
    index index.html;\n\
    gzip on;\n\
    gzip_types text/plain text/css text/javascript application/javascript application/json;\n\
    location / {\n\
        try_files $uri $uri/ /index.html;\n\
    }\n\
    location /health {\n\
        return 200 "ok";\n\
        add_header Content-Type text/plain;\n\
    }\n\
}\n' > /etc/nginx/conf.d/default.conf

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD wget -qO- http://localhost/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
