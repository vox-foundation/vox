{
  "name": "vox-mental-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "vox-sherpa-transcribe": "file:plugins/vox-sherpa-transcribe",
    "@capacitor/android": "^6.0.0",
    "@capacitor/clipboard": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "workbox-window": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@playwright/test": "^1.49.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "scripts": {
    "build:plugin": "tsc -p plugins/vox-sherpa-transcribe/tsconfig.json",
    "build:vox": "cargo run --release -q -p vox-cli --manifest-path ../../Cargo.toml -- build src/main.vox -o dist",
    "build:fixup": "node scripts/postbuild-fixup.mjs",
    "build:web": "pnpm build:vox && pnpm build:fixup && vite build",
    "dev": "pnpm build:vox && pnpm build:fixup && vite",
    "preview": "vite preview",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test"
  }
}
