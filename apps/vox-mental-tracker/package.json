{

  "name": "vox-mental-tracker",

  "version": "0.1.0",

  "private": true,

  "type": "module",

  "dependencies": {

    "@tauri-apps/api": "^2.0.0",

    "vox-tauri-sherpa-guest": "link:../../crates/vox-tauri-sherpa/guest-js",

    "react": "^19.0.0",

    "react-dom": "^19.0.0",

    "workbox-window": "^7.0.0",

    "zod": "^3.23.0"

  },

  "devDependencies": {

    "@playwright/test": "^1.49.0",

    "@types/react": "^19.2.14",

    "@types/react-dom": "^19.2.3",

    "@vitejs/plugin-react": "^4.3.0",

    "typescript": "^5.6.0",

    "vite": "^6.0.0",

    "vitest": "^2.1.0"

  },

  "scripts": {

    "build": "pnpm build:web",

    "build:vox": "cargo run --release -q -p vox-cli --manifest-path ../../Cargo.toml -- build src/main.vox -o dist",

    "build:fixup": "node scripts/postbuild-fixup.mjs",

    "build:web": "pnpm build:vox && pnpm build:fixup && vite build",

    "dev": "pnpm build:vox && pnpm build:fixup && vite",

    "preview": "vite preview",

    "test": "vitest run",

    "test:watch": "vitest",

    "e2e": "playwright test"

  }

}

