component PipelineCard(last: bool) {
    view: (
        <div class={last}>
            <span>"card"</span>
        </div>
    )
}

component Stages() {
    state stages: int = 5
    state i: int = 0
    view: (
        <PipelineCard last={i is stages}/>
    )
}

component MixedProps(label: str, size: int) {
    view: (
        <button icon="play" size={size} class={label}>
            <span>{label}</span>
        </button>
    )
}
