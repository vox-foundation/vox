// for_nested — nested for-loops with explicit indices.
// `for row, i in matrix` and `for cell, j in row` should preserve both indices.
component Matrix(matrix: any) {
    view: panel(class="matrix") {
        for row, i in matrix key=i {
            panel(class="row") {
                for cell, j in row key=j {
                    span() { cell }
                }
            }
        }
    }
}
