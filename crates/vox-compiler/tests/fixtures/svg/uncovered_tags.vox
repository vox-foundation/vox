// uncovered_tags — additional snake_case SVG forms: linear_gradient,
// fe_gaussian_blur, foreign_object — all must normalize to camelCase.
component Filtered() {
    view: svg(view_box="0 0 100 100") {
        defs() {
            linear_gradient(id="lg", x1="0", y1="0", x2="1", y2="1") {
                stop(offset="0%", stop_color="#34d399")
                stop(offset="100%", stop_color="#2563eb")
            }
            filter(id="blur") {
                fe_gaussian_blur(std_deviation="2")
            }
        }
        rect(width="100", height="100", fill="url(#lg)")
        foreign_object(x="10", y="10", width="80", height="80") {
            panel() { "html inside svg" }
        }
    }
}
