// snake_case — SVG element + attribute snake_case forms.
// Validates that `view_box`, `stroke_width`, `radial_gradient`, `pattern_units`,
// `stop_color`, `stop_opacity`, `preserve_aspect_ratio` all normalize to camelCase
// in the emitted TSX (React/SVG canonical form).

component PlayIcon() {
    view: svg(
        view_box="0 0 24 24",
        fill="none",
        stroke="currentColor",
        stroke_width="1.5",
        stroke_linecap="round",
        stroke_linejoin="round"
    ) {
        polygon(points="5 3 19 12 5 21 5 3")
    }
}

component Halo() {
    view: svg(view_box="0 0 100 60", preserve_aspect_ratio="xMidYMid meet") {
        defs() {
            pattern(id="g", width="10", height="10", pattern_units="userSpaceOnUse") {
                path(d="M 10 0 L 0 0 0 10", stroke_width="1", stroke="rgba(255,255,255,0.1)", fill="none")
            }
            radial_gradient(id="halo", cx="0.5", cy="0.5", r="0.5") {
                stop(offset="0%", stop_color="#34d399", stop_opacity="0.4")
                stop(offset="100%", stop_color="#34d399", stop_opacity="0")
            }
        }
        rect(width="100", height="60", fill="url(#g)")
    }
}
