import React from "react";

export interface StateChipProps {
  status: string;
  label: string;
  dim: boolean;
}

export function StateChip({ status, label, dim }: StateChipProps): React.ReactElement {
  return (
<div className={["flex", "flex-row", "flex items-center", "gap-1", "px-2", "py-0", "rounded-full", (dim ? "bg-white/5" : (status === "running" || status === "ok" || status === "ready" ? "bg-emerald-400/15" : (status === "warn" || status === "blocked" || status === "pending" ? "bg-amber-400/15" : (status === "error" || status === "failed" || status === "errored" ? "bg-rose-500/15" : "bg-white/5")))), "h-5 inline-flex"].filter(Boolean).join(" ")}
>
  <div className={["border", "border-border", "p-4", "w-1", "h-1", "rounded-full", (dim ? "bg-zinc-600" : (status === "running" || status === "ok" || status === "ready" ? "bg-emerald-400" : (status === "warn" || status === "blocked" || status === "pending" ? "bg-amber-400" : (status === "error" || status === "failed" || status === "errored" ? "bg-rose-500" : "bg-zinc-600"))))].filter(Boolean).join(" ")} />
  <p className={["text-xs", "font-mono", "tracking-widest", "uppercase", (dim ? "text-zinc-500" : (status === "running" || status === "ok" || status === "ready" ? "text-emerald-400" : (status === "warn" || status === "blocked" || status === "pending" ? "text-amber-400" : (status === "error" || status === "failed" || status === "errored" ? "text-rose-400" : "text-zinc-500"))))].filter(Boolean).join(" ")}
>
  {(label === "" ? status : label)}
</p>
</div>
  );
}
