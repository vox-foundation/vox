import React from "react";

import { LeftRail } from "./LeftRail";
import { StatusBar } from "./StatusBar";
import { TopBar } from "./TopBar";

export interface ShellProps {
  active: string;
  rail_collapsed: boolean;
  workspace: string;
  run_status: string;
  run_label: string;
}

export function Shell({ active, rail_collapsed, workspace, run_status, run_label }: ShellProps): React.ReactElement {
  return (
<column min_h={"screen"} overflow={"hidden"} bg={"zinc.950"} color={"zinc.100"}
>
  <TopBar workspace={workspace} run_status={run_status} run_label={run_label} />
  <row flex={1} min_h={0} overflow={"hidden"}
>
  <LeftRail active={active} collapsed={rail_collapsed} />
  <panel flex={1} min_w={0} overflow={"hidden"} bg={"zinc.950"} />
</row>
  <StatusBar active={active} />
</column>
  );
}
