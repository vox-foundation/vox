import React, { useState } from "react";

export function Panel(): React.ReactElement {
  const [label, set_label] = useState("Hello");
  return (
<div className={["flex", "flex-col", "wrap"].filter(Boolean).join(" ")}
>
  <div data-vox-island="DataChart" data-prop-title={label} />
</div>
  );
}
