import React from "react";

export interface IconBtnProps {
  icon: string;
  size: number;
  on_click: any;
}

export function IconBtn({ icon, size, on_click }: IconBtnProps): React.ReactElement {
  return (
<button size={"icon"} w={size} h={size} radius={"lg"} bg={"white/5"} color={"zinc.400"} border={true} border_color={"white/10"} raw_class={"flex items-center justify-center hover:bg-white/10"} onClick={on_click}
>
  <text size={"xs"} fontFamily={"mono"}
>
  {icon}
</text>
</button>
  );
}
