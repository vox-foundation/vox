import React from "react";

import { NavItem } from "./NavItem";

export interface LeftRailProps {
  active: string;
  collapsed: boolean;
}

export function LeftRail({ active, collapsed }: LeftRailProps): React.ReactElement {
  return (
    <div className={["flex", "flex-col", (collapsed ? "w-14 shrink-0" : "w-[200px] shrink-0"), "border-r-true", "border-zinc-800", "p-2", "gap-1", "bg-zinc-950"].filter(Boolean).join(" ")}>
      <div className={["flex", "flex-row", "h-12", "flex items-center", "shrink-0", (collapsed ? "justify-center px-1" : "gap-2 px-2")].filter(Boolean).join(" ")}>
        <div className={["border", "border-border", "p-4", "w-6", "h-6", "rounded-md", "bg-blue-600", "flex items-center justify-center shrink-0"].filter(Boolean).join(" ")} role={region}>
          <p className={["text-xs", "font-bold", "text-white", "font-mono"].filter(Boolean).join(" ")}>
            {"V"}
          </p>
        </div>
        {(collapsed ? <div className={["bg-background", "rounded-lg", "border", "border-border", "p-4"].filter(Boolean).join(" ")} /> : <p className={["text-sm", "font-bold", "text-white/90", "tracking-tight"].filter(Boolean).join(" ")}
    >
      {"Vox"}
    </p>)}
      </div>
      <NavItem active={active} collapsed={collapsed} label={"Speak"} surface_key={"speak"} />
      <NavItem active={active} collapsed={collapsed} label={"Mesh"} surface_key={"mesh"} />
      <NavItem active={active} collapsed={collapsed} label={"Forge"} surface_key={"forge"} />
      <NavItem active={active} collapsed={collapsed} label={"Code"} surface_key={"code"} />
      <NavItem active={active} collapsed={collapsed} label={"Models"} surface_key={"models"} />
      <NavItem active={active} collapsed={collapsed} label={"Runs"} surface_key={"runs"} />
      <div className={["bg-background", "rounded-lg", "border", "border-border", "p-4", "flex-1"].filter(Boolean).join(" ")} role={region} />
      <NavItem active={active} collapsed={collapsed} label={"Settings"} surface_key={"settings"} />
      {(collapsed ? <div className={["bg-background", "rounded-lg", "border", "border-border", "p-4"].filter(Boolean).join(" ")} /> : <div className={["flex", "flex-row", "px-2", "py-2", "shrink-0"].filter(Boolean).join(" ")}
    >
      <p className={["text-xs", "font-mono", "text-zinc-700"].filter(Boolean).join(" ")}
    >
      {"v0.14.2 · main"}
    </p>
    </div>)}
    </div>
  );
}
