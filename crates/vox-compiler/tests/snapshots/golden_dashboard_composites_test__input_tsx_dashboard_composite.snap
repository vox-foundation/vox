import React from "react";

export interface InputProps {
  value: string;
  mono: boolean;
  placeholder: string;
}

export function Input({ value, mono, placeholder }: InputProps): React.ReactElement {
  return (
<div className={["bg-zinc-900", "border", "border-white/10", "rounded-lg", "px-3", "py-2", "flex items-center h-9"].filter(Boolean).join(" ")}
>
  {(value === "" ? <p className={["text-sm", "text-zinc-600", (mono ? "font-mono" : "font-sans"), "italic"].filter(Boolean).join(" ")}
>
  {placeholder}
</p> : <p className={["text-sm", "text-zinc-300", (mono ? "font-mono" : "font-sans")].filter(Boolean).join(" ")}
>
  {value}
</p>)}
</div>
  );
}
