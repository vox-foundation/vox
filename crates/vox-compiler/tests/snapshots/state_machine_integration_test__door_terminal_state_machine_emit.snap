// Generated by vox-compiler — do not edit.
import { useState, useCallback } from "react";
export type Door =
   | { readonly _tag: "Open" }
   | { readonly _tag: "Locked" };

export type DoorEvent =
   | { readonly _type: "Lock" };

export function doorReducer(
  state: Door,
  event: DoorEvent,
): Door {
  switch (state._tag) {
    case "Open":
      switch (event._type) {
        case "Lock":
          return { _tag: "Locked" };
        default: return state;
      }
    default: return state;
  }
}

export function useDoorStateMachine(initial: Door): {
  state: Door;
  send: (event: DoorEvent) => void;
} {
  const [state, setState] = useState<Door>(initial);
  const send = useCallback((event: DoorEvent) => {
    setState((prev) => doorReducer(prev, event));
  }, []);
  return { state, send };
}
