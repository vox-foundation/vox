// Generated by vox-compiler — do not edit.
export type Door =
   | { readonly _tag: "Open" }
   | { readonly _tag: "Locked" };

export type DoorEvent =
   | { readonly _type: "Lock" };

export function doorReducer(
  state: Door,
  event: DoorEvent,
): Door {
  switch (state._tag) {
    case "Open":
      switch (event._type) {
        case "Lock":
          return { _tag: "Locked" };
        default: return state;
      }
    default: return state;
  }
}
