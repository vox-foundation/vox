>
  <stop offset={"0%"} stopColor={"#34d399"} stopOpacity={0.4} />
  <stop offset={"100%"} stopColor={"#34d399"} stopOpacity={0} />
</radialGradient>
</defs>
  <rect width={100} height={60} fill={"url(#halo)"} />
</svg>
  );
