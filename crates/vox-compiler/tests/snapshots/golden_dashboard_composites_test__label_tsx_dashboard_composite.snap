import React from "react";

export interface LabelProps {
  text: string;
}

export function Label({ text }: LabelProps): React.ReactElement {
  return (
<text size={"xs"} weight={"bold"} case={"upper"} tracking={"widest"} color={"zinc.500"}
>
  {text}
</text>
  );
}
