import React from "react";

export interface ToggleProps {
  checked: boolean;
  label: string;
  on_change: any;
}

export function Toggle({ checked, label, on_change }: ToggleProps): React.ReactElement {
  return (
    <div className={["flex", "flex-row", "items-center", "gap-3", "cursor-pointer"].filter(Boolean).join(" ")} onClick={on_change}>
      <div className={["border", "border-border", "w-9", "h-5", "rounded-full", (checked ? "bg-blue-600" : "bg-zinc-700"), "p-0", "relative flex items-center transition-colors duration-150"].filter(Boolean).join(" ")} role={"region"}>
        <div className={["border", "border-border", "p-4", "w-4", "h-4", "rounded-full", "bg-white", (checked ? "absolute right-0.5 transition-all duration-150" : "absolute left-0.5 transition-all duration-150")].filter(Boolean).join(" ")} role={"region"} />
      </div>
      {(label === "" ? <div className={["bg-background", "rounded-lg", "border", "border-border", "p-4"].filter(Boolean).join(" ")} /> : <p className={["text-sm", "text-zinc-300"].filter(Boolean).join(" ")}
    >
      {label}
    </p>)}
    </div>
  );
}
