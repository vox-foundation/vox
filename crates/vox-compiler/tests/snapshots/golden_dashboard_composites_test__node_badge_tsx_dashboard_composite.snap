import React from "react";

export interface NodeBadgeProps {
  id: string;
  status: string;
  role: string;
  dim: boolean;
}

export function NodeBadge({ id, status, role, dim }: NodeBadgeProps): React.ReactElement {
  return (
<row pad_x={3} pad_y={2} bg={"zinc.900"} border={true} border_color={"white/10"} radius={"xl"} items={"center"} gap={3}
>
  <panel w={2} h={2} radius={"full"} bg={(dim ? "zinc.600" : (status === "running" || status === "ok" || status === "ready" ? "emerald.400" : (status === "warn" || status === "blocked" || status === "pending" ? "amber.400" : (status === "error" || status === "failed" || status === "errored" ? "rose.500" : "zinc.600"))))} />
  <column gap={0}
>
  <text size={"xs"} fontFamily={"mono"} color={"white/80"}
>
  {id}
</text>
  {(role === "" ? <text size={"xs"} color={"zinc.500"}
>
  {status}
</text> : <row items={"center"} gap={1}
>
  <text size={"xs"} color={"zinc.500"}
>
  {status}
</text>
  <text size={"xs"} color={"zinc.700"}
>
  {"·"}
</text>
  <text size={"xs"} color={"zinc.600"} fontFamily={"mono"}
>
  {role}
</text>
</row>)}
</column>
</row>
  );
}
