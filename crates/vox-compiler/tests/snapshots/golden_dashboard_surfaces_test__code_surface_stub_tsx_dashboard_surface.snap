import React from "react";

import { StateChip } from "./StateChip";
import { SurfaceStub } from "./SurfaceStub";

export function CodeSurface(): React.ReactElement {
  return (
    <div className={["flex", "flex-col", "flex-1", "overflow-hidden", "bg-zinc-950"].filter(Boolean).join(" ")}>
      <div className={["flex", "flex-row", "h-10", "border-b", "border-zinc-800", "px-4", "items-center", "justify-between", "shrink-0"].filter(Boolean).join(" ")}>
        <p className={["text-sm", "tracking-tight", "text-white"].filter(Boolean).join(" ")}>
          {"Code"}
        </p>
        <StateChip label={"no file"} status={"idle"} />
      </div>
      <SurfaceStub action={"Open a file"} desc={"Scoped file editor for .vox, Rust, and TypeScript. File tree on the left; diagnostics and agent activity on the right."} title={"Code"} />
    </div>
  );
}
