import React from "react";

export interface StatBoxProps {
  key: string;
  value: string;
  sub: string;
}

export function StatBox({ key, value, sub }: StatBoxProps): React.ReactElement {
  return (
    <div className={["flex", "flex-col", "bg-zinc-900", "border", "border-white/10", "rounded-xl", "p-4", "gap-1"].filter(Boolean).join(" ")}>
      <p className={["text-xs", "font-bold", "uppercase", "tracking-widest", "text-zinc-500", "mb-1"].filter(Boolean).join(" ")}>
        {key}
      </p>
      <p className={["text-2xl", "font-bold", "text-white/90", "font-mono", "tracking-tight"].filter(Boolean).join(" ")}>
        {value}
      </p>
      {(sub === "" ? <div className={["bg-background", "rounded-lg", "border", "border-border", "p-4"].filter(Boolean).join(" ")} /> : <p className={["text-xs", "text-zinc-600"].filter(Boolean).join(" ")}
    >
      {sub}
    </p>)}
    </div>
  );
}
