import React from "react";

export interface KeyHintProps {
  text: string;
}

export function KeyHint({ text }: KeyHintProps): React.ReactElement {
  return (
<panel border={true} border_color={"white/15"} radius={"sm"} pad_x={1} bg={"white/5"} raw_class={"h-5 inline-flex items-center"}
>
  <text size={"xs"} fontFamily={"mono"} color={"zinc.400"}
>
  {text}
</text>
</panel>
  );
}
