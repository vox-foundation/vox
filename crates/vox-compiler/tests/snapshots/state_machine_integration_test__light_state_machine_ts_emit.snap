// Generated by vox-compiler — do not edit.
import { useState, useCallback } from "react";
export type Light =
   | { readonly _tag: "On" }
   | { readonly _tag: "Off" };

export type LightEvent =
   | { readonly _type: "Toggle" };

export function lightReducer(
  state: Light,
  event: LightEvent,
): Light {
  switch (state._tag) {
    case "On":
      switch (event._type) {
        case "Toggle":
          return { _tag: "Off" };
        default: return state;
      }
    case "Off":
      switch (event._type) {
        case "Toggle":
          return { _tag: "On" };
        default: return state;
      }
    default: return state;
  }
}

export function useLightStateMachine(initial: Light): {
  state: Light;
  send: (event: LightEvent) => void;
} {
  const [state, setState] = useState<Light>(initial);
  const send = useCallback((event: LightEvent) => {
    setState((prev) => lightReducer(prev, event));
  }, []);
  return { state, send };
}
