import React from "react";

export interface CodeframeProps {
  file: string;
  line: number;
  col: number;
  excerpt: string;
  caret: string;
}

export function Codeframe({ file, line, col, excerpt, caret }: CodeframeProps): React.ReactElement {
  return (
    <div className={["bg-zinc-900", "border", "border-white/10", "rounded-lg", "p-3", "gap-1"].filter(Boolean).join(" ")} role={region}>
      <p className={["text-xs", "font-mono", "text-zinc-500"].filter(Boolean).join(" ")}>
        {file}
      </p>
      <p className={["text-xs", "font-mono", "text-white/70", "leading-relaxed"].filter(Boolean).join(" ")}>
        {excerpt}
      </p>
      <p className={["text-xs", "font-mono", "text-rose-400"].filter(Boolean).join(" ")}>
        {caret}
      </p>
    </div>
  );
}
