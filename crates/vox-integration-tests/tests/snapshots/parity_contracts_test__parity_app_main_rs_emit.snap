// Generated by Vox Compiler
use axum::{Router, routing::{post}, Json};
use axum::response::{Response, IntoResponse};
use axum::body::Body;
use axum::http::{StatusCode, header};
use std::net::SocketAddr;
use rust_embed::Embed;
use parity_app::*;

#[derive(Embed)]
#[folder = "public/"]
struct Assets;

async fn serve_embedded(uri: axum::http::Uri) -> Response {
    let path = uri.path().trim_start_matches('/');
    let path = if path.is_empty() { "index.html" } else { path };
    match Assets::get(path) {
        Some(file) => {
            let mime = mime_guess::from_path(path).first_or_octet_stream();
            (StatusCode::OK, [(header::CONTENT_TYPE, mime.as_ref().to_string())], file.data.to_vec()).into_response()
        }
        None => {
            // SPA fallback: serve index.html for client-side routing
            match Assets::get("index.html") {
                Some(file) => (StatusCode::OK, [(header::CONTENT_TYPE, "text/html".to_string())], file.data.to_vec()).into_response(),
                None => (StatusCode::NOT_FOUND, "Not Found").into_response(),
            }
        }
    }
}

async fn serve_dispatch(req: axum::http::Request<Body>) -> Response {
    let uri = req.uri().clone();
    if *req.method() == axum::http::Method::GET {
        if let Ok(base) = std::env::var("VOX_SSR_DEV_URL") {
            let base = base.trim();
            if !base.is_empty() {
                let p = uri.path();
                if !p.starts_with("/api") {
                    let target = format!("{}{}", base.trim_end_matches('/'), uri);
                    if let Ok(client) = vox_reqwest_defaults::client_builder()
                        .timeout(std::time::Duration::from_secs(60))
                        .build()
                    {
                        if let Ok(resp) = client.get(target).send().await {
                            let status = resp.status();
                            let ct = resp.headers().get(reqwest::header::CONTENT_TYPE).cloned();
                            let bytes = resp.bytes().await.unwrap_or_default();
                            let code = axum::http::StatusCode::from_u16(status.as_u16())
                                .unwrap_or(axum::http::StatusCode::BAD_GATEWAY);
                            let mut builder = Response::builder().status(code);
                            if let Some(ct) = ct {
                                if let Ok(v) = ct.to_str() {
                                    builder = builder.header(header::CONTENT_TYPE, v);
                                }
                            }
                            if let Ok(out) = builder.body(Body::from(bytes)) {
                                return out;
                            }
                        }
                    }
                }
            }
        }
    }
    serve_embedded(uri).await
}

#[tokio::main]
async fn main() {
    tracing_subscriber::fmt::init();
    if let Ok(wf_name_raw) = std::env::var("VOX_RUN_WORKFLOW") {
        let wf_name = wf_name_raw.trim().to_string();
        if !wf_name.is_empty() {
            let args_raw = std::env::var("VOX_WORKFLOW_ARGS").unwrap_or_else(|_| "[]".to_string());
            let args: Vec<serde_json::Value> = match serde_json::from_str(&args_raw) {
                Ok(v) => v,
                Err(e) => {
                    eprintln!("Invalid VOX_WORKFLOW_ARGS JSON: {}", e);
                    std::process::exit(2);
                }
            };
            match __vox_run_workflow(&wf_name, &args).await {
                Ok(()) => {
                    vox_runtime::builtins::vox_flush_exit_commands();
                    return;
                }
                Err(e) => {
                    eprintln!("Workflow execution failed: {}", e);
                    vox_runtime::builtins::vox_flush_exit_commands();
                    std::process::exit(2);
                }
            }
        }
    }
    let app = Router::new()
        .route("/api/chat", post(handle_sf_chat))
        .fallback(serve_dispatch);

    let port: u16 = std::env::var("VOX_PORT")
        .ok()
        .and_then(|s| s.parse().ok())
        .unwrap_or(3000);
    let addr = SocketAddr::from(([127, 0, 0, 1], port));
    println!("Listening on {}", addr);
    let listener = tokio::net::TcpListener::bind(addr).await.expect("Failed to bind TCP listener");
    axum::serve(listener, app).await.expect("Server exited with error");
    vox_runtime::builtins::vox_flush_exit_commands();
}

async fn handle_sf_chat(Json(request): Json<serde_json::Value>) -> Json<serde_json::Value> {
    let prompt = request["prompt"].clone();
    return Json(serde_json::to_value(prompt.clone()).expect("vox codegen: route return JSON"));
}
