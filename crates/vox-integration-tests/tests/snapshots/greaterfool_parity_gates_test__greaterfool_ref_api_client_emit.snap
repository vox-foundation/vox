// Auto-generated API client for Vox server functions
// @query → GET + JSON query values; @server / @mutation → POST + JSON body.
// Do not edit manually — regenerated on each build.

const API_BASE = '';

export async function chat(prompt: string, request_id: string, conversation_id: string): Promise<Result<string>> {
  const response = await fetch(`${API_BASE}/api/chat`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ prompt, request_id, conversation_id }),
  });
  if (!response.ok) throw new Error(`Server error: ${response.status}`);
  return response.json();
}
