use serde::{Serialize, Deserialize};

pub fn as_string<T: serde::Serialize>(v: &T) -> String {
    let val = serde_json::to_value(v).expect("vox codegen: serde_json::to_value failed");
    if let Some(s) = val.as_str() { s.to_string() } else { val.to_string() }
}

fn f() -> i64 {
    let x = vox_actor_runtime::execute_activity_result("activity", &vox_actor_runtime::ActivityOptions::new().with_retries(5 as u32).with_timeout(vox_actor_runtime::ActivityOptions::parse_duration("30s").expect("vox codegen: activity timeout duration")).with_activity_id("unique-xyz".to_string()).with_backoff_multiplier(2 as f64), || async { 1 }).await;
    return x.clone();
}
