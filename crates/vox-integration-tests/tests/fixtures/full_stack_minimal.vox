# Minimal full-stack surface — v0.3 brace syntax
# Path C `component`, `routes`, `http`, and `@server`.
# Used as a golden input for `vox build` integration tests.

type PingMsg =
    | Pong(text: str)

component Home() {
    state n: int = 0
    view: (
        <div class="wrap">
            <p>"n = " {n}</p>
            <button on:click={n = n + 1}>"+"</button>
        </div>
    )
}

routes {
    "/" to Home
}

http get "/api/ping" to PingMsg {
    ret Pong("ok")
}

@server fn echo(x: str) to str {
    ret x
}
