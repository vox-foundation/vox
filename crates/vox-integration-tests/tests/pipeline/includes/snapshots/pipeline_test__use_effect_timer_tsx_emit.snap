import React, { useState, useEffect } from "react";

export function Timer(): React.ReactElement {
    const [count, set_count] = useState(0);
    useEffect(((_x) => (count)));
  return (
    <div>
      {(() => {
        count;
      })()}
    </div>
  );
}
