import React, { useState } from "react";

export function Dash(): React.ReactElement {
  const [n, set_n] = useState(0);
  return (
    <div className={["flex", "flex-col", "dashboard"].filter(Boolean).join(" ")}>
      {n}
    </div>
  );
}
