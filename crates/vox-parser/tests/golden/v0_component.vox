# Vox v0.dev Component Demo — v0.3 brace syntax
# Demonstrates @v0 declarations — AI-generated UI component stubs.

# Prompt-based v0 component: describe the UI in plain language.
@v0 "A modern analytics dashboard with a sidebar nav, KPI metric cards showing revenue/users/conversion, a line chart for trend data, and a data table with sortable columns" fn Analytics() to Element

# Image-based v0 component: reference a design mockup file.
@v0 from "design/landing-mockup.png" fn LandingPage() to Element

# Another prompt-based component for a settings panel.
@v0 "A user settings panel with profile photo upload, name/email fields, notification toggles, and a danger zone delete account section" fn SettingsPanel() to Element

routes {
    "/" to Analytics
    "/landing" to LandingPage
    "/settings" to SettingsPanel
}
