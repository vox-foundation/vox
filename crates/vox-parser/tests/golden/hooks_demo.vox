# Vox React Hooks Demo — v0.3 brace syntax
# Demonstrates all five React hook bindings: use_state, use_effect, use_memo, use_ref, use_callback

import react.use_state
import react.use_effect
import react.use_memo
import react.use_ref
import react.use_callback

@component fn HooksDemo() to Element {
    let (count, set_count) = use_state(0)
    let (name, set_name) = use_state("World")
    let doubled = use_memo(fn(_x) count * 2)
    let input_ref = use_ref(0)
    let increment = use_callback(fn(_e) set_count(count + 1))
    use_effect(fn(_x) count)
    <div class="hooks_demo">
        <h1>"Hello, " {name} "!"</h1>
        <p>"Count: " {count}</p>
        <p>"Doubled: " {doubled}</p>
        <div class="controls">
            <button on_click={increment}>"Increment"</button>
            <button on_click={fn(_e) set_count(0)}>"Reset"</button>
        </div>
        <div class="name_input">
            <input bind={name} placeholder="Enter your name" />
        </div>
    </div>
}

style {
    .hooks_demo {
        fontFamily: "sans-serif"
        maxWidth: "480px"
        margin: "2rem auto"
        padding: "2rem"
        borderRadius: "12px"
        boxShadow: "0 2px 12px rgba(0,0,0,0.1)"
    }
    .controls {
        display: "flex"
        gap: "0.75rem"
        marginBottom: "1.5rem"
    }
    .name_input {
        display: "flex"
        flexDirection: "column"
        gap: "0.5rem"
    }
}

routes {
    "/" to HooksDemo
}
