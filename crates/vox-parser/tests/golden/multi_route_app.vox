# Vox Multi-Route Full-Stack App — v0.3 brace syntax
# Demonstrates: multiple @component, routes, http endpoints,
# @server fn, style, actor, for loops, use_state — all in one file.

import react.use_state

# --- Types ---

type Todo =
    | Active(text: str)
    | Completed(text: str)

type StatsResult =
    | Stats(total: int, done: int)

# --- Components ---

@component fn Dashboard() to Element {
    let (visits, set_visits) = use_state(0)
    <div class="dashboard">
        <h1>"Dashboard"</h1>
        <p>"Visits: " {visits}</p>
        <button on_click={fn(_e) set_visits(visits + 1)}>"Track Visit"</button>
    </div>
}

@component fn TodoList() to Element {
    let (items, set_items) = use_state([])
    let (draft, set_draft) = use_state("")
    let add = fn(_e) set_items(items.append({text: draft, done: false}))
    <div class="todo_list">
        <h1>"Todo List"</h1>
        <div class="input_row">
            <input bind={draft} placeholder="New task..." />
            <button on_click={add}>"Add"</button>
        </div>
        <ul class="items">
            for item in items {
                <li class="item">{item.text}</li>
            }
        </ul>
    </div>
}

@component fn About() to Element {
    <div class="about">
        <h1>"About"</h1>
        <p>"Built with Vox — the AI-native full-stack language."</p>
    </div>
}

# --- Styles ---

style {
    .dashboard {
        fontFamily: "sans-serif"
        padding: "2rem"
        maxWidth: "600px"
        margin: "0 auto"
    }
    .todo_list {
        fontFamily: "sans-serif"
        padding: "2rem"
        maxWidth: "600px"
        margin: "0 auto"
    }
    .input_row {
        display: "flex"
        gap: "0.5rem"
        marginBottom: "1rem"
    }
    .items {
        listStyle: "none"
        padding: "0"
    }
    .item {
        padding: "0.5rem"
        borderBottom: "1px solid #eee"
    }
    .about {
        fontFamily: "sans-serif"
        padding: "2rem"
        maxWidth: "600px"
        margin: "0 auto"
    }
}

# --- Routes ---

routes {
    "/" to Dashboard
    "/todos" to TodoList
    "/about" to About
}

# --- HTTP API ---

http get "/api/todos" to str {
    ret "[]"
}

http post "/api/todos" to str {
    let body = request.json()
    ret "created"
}

http delete "/api/todos" to str {
    ret "ok"
}

# --- Server Functions ---

@server fn get_stats() to StatsResult {
    ret Stats(42, 17)
}

@server fn reset_counter() to str {
    ret "reset"
}

# --- Actors ---

actor StatsTracker {
    on increment(label: str) to int {
        let current = state_load("count")
        let next = current + 1
        state_save("count", next)
        ret next
    }
}
