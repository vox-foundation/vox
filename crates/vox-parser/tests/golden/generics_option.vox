# Vox ADT, Option, and Result Example — v0.3 brace syntax
# Demonstrates: type, ADTs, Option, Result, pattern matching, @test

# Option ADT — represents an optional value (no null)
type Option =
    | Some(value: str)
    | None

# Result ADT — represents success or failure
type Result =
    | Ok(value: str)
    | Err(message: str)

# Unwrap an Option with a fallback default value
fn unwrap_or(opt: Option, default: str) to str {
    match opt {
        Some(value) -> value
        None -> default
    }
}

# Chain results: if the first is Ok, return the second; otherwise propagate Err
fn chain(first: Result, second: Result) to Result {
    match first {
        Ok(v) -> second
        Err(msg) -> Err(msg)
    }
}

# Wrap a string in an Ok result
fn wrap_ok(s: str) to Result {
    Ok(s)
}

# Wrap an error message in an Err result
fn wrap_err(msg: str) to Result {
    Err(msg)
}

@test fn test_unwrap_some() to Unit {
    let opt = Some("hello")
    let result = unwrap_or(opt, "default")
    assert(result is "hello")
}

@test fn test_unwrap_none() to Unit {
    let opt = None
    let result = unwrap_or(opt, "fallback")
    assert(result is "fallback")
}

@test fn test_ok_result() to Unit {
    let r = Ok("success")
    match r {
        Ok(value) -> assert(value is "success")
        Err(msg) -> assert(false)
    }
}

@test fn test_err_result() to Unit {
    let r = Err("something went wrong")
    match r {
        Ok(value) -> assert(false)
        Err(msg) -> assert(msg is "something went wrong")
    }
}

@test fn test_chain_ok_ok() to Unit {
    let first = Ok("step1")
    let second = Ok("step2")
    let result = chain(first, second)
    match result {
        Ok(value) -> assert(value is "step2")
        Err(msg) -> assert(false)
    }
}

@test fn test_chain_err_propagates() to Unit {
    let first = Err("failed early")
    let second = Ok("never reached")
    let result = chain(first, second)
    match result {
        Ok(value) -> assert(false)
        Err(msg) -> assert(msg is "failed early")
    }
}
