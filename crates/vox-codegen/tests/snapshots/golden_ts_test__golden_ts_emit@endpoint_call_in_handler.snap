import React, { useState } from "react";

import { get_count } from "./vox-client";

export function Counter(): React.ReactElement {
  const [count, set_count] = useState(0);
  return (
    <div className={["flex", "flex-col"].filter(Boolean).join(" ")}>
      <p className={"text-base"}>
        {"Value: " + String(count)}
      </p>
      <button className={["inline-flex", "items-center", "justify-center", "rounded-md", "text-sm", "font-medium", "ring-offset-background", "transition-colors", "focus-visible:outline-none", "focus-visible:ring-2", "focus-visible:ring-ring", "focus-visible:ring-offset-2", "disabled:pointer-events-none", "disabled:opacity-50", "bg-primary", "text-primary-foreground", "hover:bg-primary/90", "h-10", "px-4", "py-2"].filter(Boolean).join(" ")} onClick={async () => {
        set_count(await get_count());
    }}>
        {"Fetch"}
      </button>
    </div>
  );
}


