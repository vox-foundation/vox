{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/contracts/scientia/novelty-evidence-bundle.v1.schema.json",
  "title": "SCIENTIA novelty evidence bundle v1",
  "description": "Normalized prior-art / overlap snapshot from federated sources (OpenAlex, Crossref, Semantic Scholar, …) with deterministic digests for audit.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "candidate_id",
    "computed_at_ms",
    "query_digest_sha256",
    "sources",
    "normalized_hits"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "bundle_id": { "type": "string", "minLength": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "computed_at_ms": { "type": "integer" },
    "query_digest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["openalex", "crossref", "semantic_scholar", "manual", "other"]
      }
    },
    "normalized_hits": {
      "type": "array",
      "items": { "$ref": "#/$defs/normalized_hit" }
    },
    "overlap_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_lexical_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "max_semantic_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "recency_bucket": {
          "type": "string",
          "enum": ["unknown", "stale", "recent", "very_recent"]
        }
      }
    },
    "query_traces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "request_fingerprint_sha256"],
        "properties": {
          "source": { "type": "string" },
          "request_fingerprint_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "http_status": { "type": "integer" },
          "cached": { "type": "boolean" }
        }
      }
    }
  },
  "$defs": {
    "normalized_hit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "work_uri", "title"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["openalex", "crossref", "semantic_scholar", "manual", "other"]
        },
        "work_uri": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "year": { "type": "integer" },
        "lexical_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "semantic_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "overlap_note": { "type": "string" },
        "cited_by_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional citation count from upstream API (e.g. OpenAlex, Semantic Scholar)."
        }
      }
    }
  }
}
