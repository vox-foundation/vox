{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox/contracts/scientia/distribution.schema.json",
  "title": "ScientiaDistribution",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "channels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "rss",
          "twitter",
          "github",
          "open_collective",
          "reddit",
          "hacker_news",
          "youtube",
          "crates_io"
        ]
      }
    },
    "channel_payloads": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "twitter": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "short_text": { "type": "string" },
            "thread": { "type": "boolean" }
          }
        },
        "github": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repo": { "type": "string", "minLength": 1 },
            "post_type": { "type": "string", "enum": ["Release", "Discussion"] },
            "release_tag": { "type": "string" },
            "draft": { "type": "boolean" },
            "discussion_category": { "type": "string" }
          }
        },
        "open_collective": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "is_private": { "type": "boolean" },
            "collective_slug": { "type": "string", "minLength": 1 }
          },
          "required": ["collective_slug"]
        },
        "reddit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "subreddit": { "type": "string", "minLength": 1 },
            "kind": { "type": "string", "enum": ["link", "self_post"] },
            "title_override": { "type": "string" },
            "text_override": { "type": "string" },
            "url_override": { "type": "string" },
            "nsfw": { "type": "boolean" },
            "spoiler": { "type": "boolean" },
            "send_replies": { "type": "boolean" }
          },
          "required": ["subreddit"]
        },
        "hacker_news": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mode": { "type": "string", "enum": ["manual_assist"] },
            "title_override": { "type": "string" },
            "url_override": { "type": "string" }
          }
        },
        "youtube": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "video_asset_ref": { "type": "string", "minLength": 1 },
            "title_override": { "type": "string" },
            "description_override": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } },
            "category_id": { "type": "string" },
            "privacy_status": {
              "type": "string",
              "enum": ["private", "unlisted", "public"]
            },
            "notify_subscribers": { "type": "boolean" }
          },
          "required": ["video_asset_ref"]
        },
        "crates_io": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "crates_to_update": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "required": ["crates_to_update"]
        }
      }
    },
    "channel_policy": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "template_profile": { "type": "string" },
          "worthiness_floor": { "type": "number", "minimum": 0, "maximum": 1 },
          "topic_filters": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "include_tags": {
                "type": "array",
                "items": { "type": "string" }
              },
              "exclude_tags": {
                "type": "array",
                "items": { "type": "string" }
              },
              "min_topic_score": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    },
    "crosspost_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" }
        },
        "required": ["from", "to"]
      }
    },
    "distribution_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "retry_profile": { "type": "string" },
        "rate_limit_profile": { "type": "string" },
        "approval_required": { "type": "boolean" },
        "dry_run": { "type": "boolean" },
        "channel_policy": { "$ref": "#/properties/channel_policy" }
      }
    }
  }
}
