{
  "x-vox-version": 1,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/contracts/scientia/finding-candidate.v1.schema.json",
  "title": "SCIENTIA finding candidate ledger record v1",
  "description": "Canonical candidate from internal signals through novelty evidence to worthiness decision traces. internal_signals align with discovery-signal.schema.json (validated separately or embedded here).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "candidate_class",
    "internal_signals",
    "created_at_ms"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "candidate_class": {
      "type": "string",
      "enum": [
        "algorithmic_improvement",
        "reproducibility_infra",
        "policy_governance",
        "telemetry_trust",
        "other"
      ]
    },
    "publication_id": { "type": "string" },
    "title_hint": { "type": "string" },
    "internal_signals": {
      "type": "array",
      "items": { "$ref": "#/$defs/discovery_signal_shape" }
    },
    "novelty_evidence_bundle_id": { "type": "string" },
    "worthiness_decision_ref": { "type": "string" },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signal_strength": { "type": "number", "minimum": 0, "maximum": 1 },
        "contradiction_risk": { "type": "number", "minimum": 0, "maximum": 1 },
        "reproducibility_support": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "created_at_ms": { "type": "integer" },
    "updated_at_ms": { "type": "integer" }
  },
  "$defs": {
    "discovery_signal_shape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "summary", "strength", "family", "provenance"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "strength": {
          "type": "string",
          "enum": ["supporting", "strong", "informational"]
        },
        "source_ref": { "type": "string" },
        "family": {
          "type": "string",
          "enum": [
            "unspecified",
            "eval_gate",
            "benchmark_pair",
            "documentation",
            "telemetry_aggregate",
            "operator_attestation",
            "mens_scorecard",
            "trust_rollup",
            "reproducibility_artifact",
            "linked_corpus",
            "finding_candidate_signal"
          ]
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "origin": { "type": "string" },
            "repo_path": { "type": "string" },
            "metric_type": { "type": "string" },
            "run_id": { "type": "string" },
            "recorded_at_ms": { "type": "integer" },
            "digest": { "type": "string" }
          }
        }
      }
    }
  }
}
