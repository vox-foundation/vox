{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/contracts/scientia/worthiness-signals.v2.schema.json",
  "title": "SCIENTIA worthiness signals v2",
  "description": "Profile-aware signal output contract for publication-worthiness v2.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "profile", "hard_gate", "soft_gate", "diagnostic", "next_actions"],
  "properties": {
    "version": { "type": "string", "const": "v2" },
    "profile": {
      "type": "string",
      "enum": ["journal", "preprint", "repository", "social"]
    },
    "hard_gate": { "$ref": "#/$defs/signalArray" },
    "soft_gate": { "$ref": "#/$defs/signalArray" },
    "diagnostic": { "$ref": "#/$defs/signalArray" },
    "next_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/actionItem" }
    }
  },
  "$defs": {
    "signalArray": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "passed", "score", "reason_code"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
          "passed": { "type": "boolean" },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "reason_code": { "type": "string", "minLength": 1 },
          "details": { "type": "string" }
        }
      }
    },
    "actionItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "priority", "action"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
        "priority": { "type": "integer", "minimum": 1, "maximum": 999 },
        "action": { "type": "string", "minLength": 1 }
      }
    }
  }
}
