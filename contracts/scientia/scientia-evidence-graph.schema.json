{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/contracts/scientia/scientia-evidence-graph.schema.json",
  "title": "metadata_json.scientia_evidence graph",
  "description": "Shared evidence bundle for scholarly + social automation. Optional fields extend over time.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "socrates_aggregate": { "type": "object" },
    "eval_gate": { "type": "object" },
    "benchmark": { "type": "object" },
    "discovery_signals": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "draft_preparation": { "type": "object" },
    "candidate_note": { "type": "string" },
    "eval_gate_run_dir_repo_relative": { "type": "string" },
    "eval_gate_report_repo_relative": { "type": "string" },
    "benchmark_pair_report_repo_relative": { "type": "string" },
    "human_meaningful_advance": { "type": "boolean" },
    "human_ai_disclosure_complete": { "type": "boolean" },
    "linked_doc_repo_relatives": {
      "type": "array",
      "items": { "type": "string" }
    },
    "mens_scorecard_repo_relative": { "type": "string" },
    "reproducibility_manifest_repo_relative": { "type": "string" },
    "trust_rollup_repo_relative": { "type": "string" },
    "signal_conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["summary"],
        "additionalProperties": false,
        "properties": {
          "codes": { "type": "array", "items": { "type": "string" } },
          "summary": { "type": "string" }
        }
      }
    },
    "doc_section_hints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "heading_level": { "type": "integer", "minimum": 1, "maximum": 6 },
          "slug": { "type": "string" },
          "title": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "autofill_provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "facet": { "type": "string" },
          "origin": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
