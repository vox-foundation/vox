{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/contracts/scientia/canonical-publication-metadata.v1.schema.json",
  "title": "SCIENTIA canonical publication metadata v1",
  "description": "Single-source manifest-centered metadata graph used for route-specific transformation (Crossref, DataCite, Zenodo, arXiv handoff, OpenReview, syndication).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "identity",
    "contributors",
    "provenance",
    "policy",
    "rights_and_funding",
    "distribution"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v1"
    },
    "schema_version": {
      "type": "string",
      "enum": ["1.0", "1.1"]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "abstract", "keywords", "target_profile"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "abstract": { "type": "string", "minLength": 1 },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "target_profile": {
          "type": "string",
          "enum": ["journal", "preprint", "repository", "social"]
        }
      }
    },
    "contributors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authors"],
      "properties": {
        "authors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "orcid": { "type": "string" },
              "affiliation": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "ror": { "type": "string" }
                }
              },
              "roles": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publication_id", "manifest_digest"],
      "properties": {
        "publication_id": { "type": "string", "minLength": 1 },
        "manifest_digest": { "type": "string", "minLength": 16 },
        "evidence_pack_digest": { "type": "string" },
        "repository_id": { "type": "string" },
        "commit_sha": { "type": "string" },
        "supersedes_publication_id": { "type": "string" },
        "corrects_publication_id": { "type": "string" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ai_disclosure"],
      "properties": {
        "ai_disclosure": {
          "type": "object",
          "additionalProperties": false,
          "required": ["declared"],
          "properties": {
            "declared": { "type": "boolean" },
            "tools": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "version": { "type": "string" },
                  "scope": { "type": "string" }
                }
              }
            }
          }
        },
        "ethics_statement": { "type": "string" },
        "broader_impact_statement": { "type": "string" },
        "double_blind_ready": { "type": "boolean" }
      }
    },
    "rights_and_funding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "license": { "type": "string" },
        "funding": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "award_number": { "type": "string" },
              "funder_id": { "type": "string" }
            }
          }
        },
        "conflict_of_interest": { "type": "string" }
      }
    },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["routes"],
      "properties": {
        "routes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["crossref", "datacite", "zenodo", "arxiv_handoff", "openreview", "social"]
          }
        },
        "primary_doi": { "type": "string" },
        "canonical_repo_url": { "type": "string" },
        "og_image_url": { "type": "string" },
        "preferred_citation": { "type": "string" },
        "embargo_lift_utc": { "type": "string", "format": "date-time" },
        "distribution_policy_ref": { "type": "string" }
      }
    },
    "evidence": { "type": "object" }
  }
}
