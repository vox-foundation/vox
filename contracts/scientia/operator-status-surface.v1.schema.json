{
  "x-vox-version": 1,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/contracts/scientia/operator-status-surface.v1.schema.json",
  "title": "SCIENTIA operator status surface v1",
  "description": "Shared CLI/MCP read-model contract for publication status views.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "publication_id",
    "profile",
    "snapshot_summary",
    "next_actions",
    "route_readiness"
  ],
  "properties": {
    "publication_id": { "type": "string", "minLength": 1 },
    "profile": { "type": "string", "minLength": 1 },
    "snapshot_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hard_gate_failures", "soft_gate_failures"],
      "properties": {
        "hard_gate_failures": { "type": "integer", "minimum": 0 },
        "soft_gate_failures": { "type": "integer", "minimum": 0 },
        "diagnostic_count": { "type": "integer", "minimum": 0 }
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "action"],
        "properties": {
          "priority": { "type": "integer", "minimum": 1, "maximum": 999 },
          "action": { "type": "string" }
        }
      }
    },
    "route_readiness": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["route", "ready"],
        "properties": {
          "route": { "type": "string" },
          "ready": { "type": "boolean" },
          "missing_required": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
