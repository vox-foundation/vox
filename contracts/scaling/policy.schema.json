{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/scaling-policy.schema.json",
  "title": "Vox scaling policy",
  "type": "object",
  "required": ["schema_version"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "baseline_id": { "type": "string" },
    "thresholds": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "max_file_bytes_hint": { "type": "integer", "minimum": 0 },
        "corpus_validate_batch_lines": { "type": "integer", "minimum": 1 }
      }
    },
    "path_literals": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mens_runs_variants": {
          "type": "array",
          "items": { "type": "string" }
        },
        "extra_flag_literals": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "magic_numeric_hints": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 }
    },
    "per_crate_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["crate_name"],
        "additionalProperties": true,
        "properties": {
          "crate_name": { "type": "string" },
          "allow_blocking_fs_in_async": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
