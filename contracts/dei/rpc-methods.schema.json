{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/dei/rpc-methods.schema.json",
  "title": "Vox Dei JSON-line dispatch request",
  "description": "One JSON object per line on stdin/stdout (`id`, `method`, `params`), matching `vox_cli::dispatch_protocol::DispatchRequest` and `vox_mcp::dei_ipc` wire shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "method",
    "params"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Correlation id for the request/response pair."
    },
    "method": {
      "type": "string",
      "enum": [
        "ai.check",
        "ai.fix",
        "ai.review",
        "ai.generate",
        "config.get",
        "ai.plan.new",
        "ai.plan.replan",
        "ai.plan.status",
        "ai.plan.execute"
      ]
    },
    "params": {
      "type": "object",
      "description": "Method-specific params payload."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "method": {
            "const": "ai.check"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "mode": {
                "type": "string"
              }
            },
            "required": [
              "path"
            ],
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "ai.fix"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "error": {
                "type": "string"
              }
            },
            "required": [
              "path"
            ],
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "ai.review"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "diff": {
                "type": "string"
              }
            },
            "required": [
              "path"
            ],
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "ai.generate"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "properties": {
              "prompt": {
                "type": "string"
              },
              "mode": {
                "type": "string"
              }
            },
            "required": [
              "prompt"
            ],
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "config.get"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "properties": {
              "key": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "ai.plan.new"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "properties": {
              "goal": {
                "type": "string"
              },
              "session_id": {
                "type": "string"
              },
              "mode": {
                "type": "string"
              }
            },
            "required": [
              "goal"
            ],
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "ai.plan.execute"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "properties": {
              "session_id": {
                "type": "string"
              },
              "mode": {
                "type": "string"
              }
            },
            "required": [
              "session_id"
            ],
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "ai.plan.replan"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "properties": {
              "session_id": {
                "type": "string"
              },
              "delta_hint": {
                "type": "string"
              },
              "mode": {
                "type": "string"
              }
            },
            "required": [
              "session_id"
            ],
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "ai.plan.status"
          }
        }
      },
      "then": {
        "properties": {
          "params": {
            "type": "object",
            "properties": {
              "session_id": {
                "type": "string"
              }
            },
            "required": [
              "session_id"
            ],
            "additionalProperties": true
          }
        }
      }
    }
  ]
}
