{
  "x-vox-version": 1,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox.local/contracts/toestub/toestub-run-json.v1.schema.json",
  "title": "TOESTUB CLI JSON output (v1 envelope)",
  "type": "object",
  "required": [
    "schema_version",
    "tool_version",
    "files_scanned",
    "rules_applied",
    "rust_parse_failures",
    "findings"
  ],
  "properties": 
    "schema_version":  "type": "integer", "const": 1 },
    "tool_version":  "type": "string" },
    "files_scanned":  "type": "integer", "minimum": 0 },
    "rules_applied":  "type": "integer", "minimum": 0 },
    "rust_parse_failures":  "type": "integer", "minimum": 0 },
    "unresolved_ref_hot_callers": 
      "type": "array",
      "items":  "type": "object" }
    },
    "suppressions_applied":  "type": "integer", "minimum": 0 },
    "suppression_counts_by_family": 
      "type": "object",
      "additionalProperties":  "type": "integer", "minimum": 0 }
    },
    "findings": 
      "type": "array",
      "items":  "type": "object" }
    }
  },
  "additionalProperties": true
}
