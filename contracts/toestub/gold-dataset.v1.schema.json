{
  "x-vox-version": 1,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox.local/contracts/toestub/gold-dataset.v1.schema.json",
  "title": "TOESTUB gold / eval fixture (v1 draft)",
  "type": "object",
  "properties": 
    "version":  "type": "integer", "const": 1 },
    "cases": 
      "type": "array",
      "items": 
        "type": "object",
        "required": ["id", "label", "rule_id_prefix", "path", "line"],
        "properties": 
          "id":  "type": "string" },
          "label": 
            "type": "string",
            "enum": ["true_positive", "false_positive", "false_negative"]
          },
          "rule_id_prefix":  "type": "string" },
          "path":  "type": "string" },
          "line":  "type": "integer", "minimum": 1 },
          "notes":  "type": "string" },
          "snippet": 
            "type": "string",
            "description": "Synthetic source used by the gold harness when file is not repo-relative."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "required": ["version", "cases"],
  "additionalProperties": false
}
