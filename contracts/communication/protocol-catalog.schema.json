{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/communication-protocol-catalog.schema.json",
  "title": "Vox communication protocol catalog",
  "type": "object",
  "required": ["schema_version", "delivery_planes", "protocol_families"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "delivery_planes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/deliveryPlane" }
    },
    "protocol_families": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/protocolFamily" }
    }
  },
  "$defs": {
    "pathList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deliveryPlane": {
      "type": "object",
      "required": [
        "id",
        "name",
        "scope",
        "pattern",
        "ordering",
        "durability",
        "retry_model",
        "ack_semantics",
        "idempotency",
        "auth_boundary",
        "use_for"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "enum": ["same_process", "same_host", "remote_network", "mixed"]
        },
        "pattern": {
          "type": "string",
          "enum": ["request_response", "push", "stream", "fanout", "hybrid"]
        },
        "ordering": {
          "type": "string",
          "minLength": 1
        },
        "durability": {
          "type": "string",
          "enum": ["none", "optional", "durable", "mixed"]
        },
        "retry_model": {
          "type": "string",
          "minLength": 1
        },
        "ack_semantics": {
          "type": "string",
          "minLength": 1
        },
        "idempotency": {
          "type": "string",
          "enum": [
            "not_applicable",
            "caller_defined",
            "transport_defined",
            "optional",
            "mixed"
          ]
        },
        "auth_boundary": {
          "type": "string",
          "enum": ["none", "host_session", "bearer_or_jwt", "upstream_protocol", "mixed"]
        },
        "use_for": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "protocolFamily": {
      "type": "object",
      "required": [
        "id",
        "display_name",
        "category",
        "status",
        "owner",
        "delivery_planes",
        "wire_formats",
        "machine_contract_paths",
        "prose_reference_paths",
        "primary_implementation_paths",
        "auth_model",
        "retirement_decision",
        "coexistence_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9.-]*$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "in_process",
            "stdio_rpc",
            "json_line_rpc",
            "json_rpc",
            "http_api",
            "http_stream",
            "websocket",
            "durable_queue",
            "broadcast",
            "webhook"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["current", "experimental", "legacy"]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "delivery_planes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_]*$"
          }
        },
        "wire_formats": {
          "$ref": "#/$defs/pathList"
        },
        "machine_contract_paths": {
          "$ref": "#/$defs/pathList"
        },
        "prose_reference_paths": {
          "$ref": "#/$defs/pathList"
        },
        "primary_implementation_paths": {
          "$ref": "#/$defs/pathList"
        },
        "telemetry_evidence_paths": {
          "$ref": "#/$defs/pathList"
        },
        "auth_model": {
          "type": "string",
          "minLength": 1
        },
        "retirement_decision": {
          "type": "string",
          "enum": ["keep", "evaluate", "replace"]
        },
        "coexistence_notes": {
          "type": "string",
          "minLength": 1
        },
        "x-orchestrator-placement-reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
