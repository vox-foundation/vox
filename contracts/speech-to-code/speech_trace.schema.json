{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox.dev/schemas/speech-to-code/speech_trace.schema.json",
  "title": "SpeechToCodeTrace",
  "type": "object",
  "required": ["schema_version", "session_id", "refined_transcript"],
  "properties": {
    "schema_version": { "type": "string", "const": "1" },
    "correlation_id": { "type": "string" },
    "session_id": { "type": "string" },
    "raw_transcript": { "type": "string" },
    "refined_transcript": { "type": "string" },
    "transcript_alternatives": {
      "type": "array",
      "items": { "type": "string" }
    },
    "intent_action": { "type": "string" },
    "intent_slots": { "type": "object" },
    "repair_attempts": { "type": "integer", "minimum": 0 },
    "compile_ok": { "type": "boolean" },
    "failure_category": {
      "type": "string",
      "enum": [
        "acoustic",
        "lexical",
        "syntactic",
        "semantic",
        "orchestration",
        "unknown"
      ]
    },
    "diagnostics_snapshot": {
      "type": "array",
      "description": "Structured compiler/LSP diagnostics for repair loops (codes align with vox_compiler::typeck::Diagnostic).",
      "items": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "code": { "type": "string" },
          "category": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning"] },
          "message": { "type": "string" },
          "start_line": { "type": "integer", "minimum": 0 },
          "start_character": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
