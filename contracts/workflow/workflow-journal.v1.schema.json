{
  "x-vox-version": 1,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/contracts/workflow/workflow-journal.v1.schema.json",
  "title": "Interpreted workflow journal event (v1)",
  "description": "Contract for events emitted by vox-workflow-runtime interpreted durable workflow runner.",
  "type": "object",
  "required": [
    "journal_version",
    "event"
  ],
  "properties": {
    "journal_version": {
      "const": 1
    },
    "event": {
      "type": "string",
      "enum": [
        "WorkflowStarted",
        "WorkflowCompleted",
        "ActivityTask",
        "ActivityStarted",
        "ActivityCompleted",
        "ActivitySkipped",
        "ActivityReplayed",
        "ActivityAttemptFailed",
        "ActivityAttemptRecovered",
        "ActivityRetryScheduled",
        "LocalActivity",
        "BranchDecision",
        "TimerWaitCompleted",
        "SignalWaitSatisfied",
        "MeshActivity",
        "MeshActivitySkipped"
      ]
    }
  },
  "oneOf": [
    {
      "required": [
        "event",
        "workflow",
        "activity",
        "activity_id",
        "resume_attempt",
        "max_attempts_window"
      ],
      "properties": {
        "event": {
          "const": "ActivityAttemptRecovered"
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "resume_attempt": {
          "type": "integer",
          "minimum": 2
        },
        "max_attempts_window": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "workflow",
        "activity",
        "activity_id",
        "execution_boundary",
        "max_attempts",
        "idempotency_key"
      ],
      "properties": {
        "event": {
          "const": "ActivityTask"
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "execution_boundary": {
          "type": "string",
          "enum": [
            "local",
            "mesh"
          ]
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "workflow",
        "steps"
      ],
      "properties": {
        "event": {
          "const": "WorkflowStarted"
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "steps": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "workflow"
      ],
      "properties": {
        "event": {
          "const": "WorkflowCompleted"
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "workflow",
        "activity",
        "activity_id"
      ],
      "properties": {
        "event": {
          "const": "ActivityStarted"
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "workflow",
        "activity",
        "activity_id"
      ],
      "properties": {
        "event": {
          "const": "ActivityCompleted"
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "replayed": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "workflow",
        "activity",
        "activity_id",
        "reason"
      ],
      "properties": {
        "event": {
          "const": "ActivitySkipped"
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "workflow",
        "activity",
        "activity_id",
        "replay_source",
        "result_event"
      ],
      "properties": {
        "event": {
          "const": "ActivityReplayed"
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "replay_source": {
          "const": "workflow_activity_log"
        },
        "result_event": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "workflow",
        "activity",
        "activity_id",
        "attempt",
        "max_attempts",
        "error"
      ],
      "properties": {
        "event": {
          "const": "ActivityAttemptFailed"
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "error": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "workflow",
        "activity",
        "activity_id",
        "attempt",
        "next_attempt",
        "delay_ms"
      ],
      "properties": {
        "event": {
          "const": "ActivityRetryScheduled"
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "next_attempt": {
          "type": "integer",
          "minimum": 2
        },
        "delay_ms": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "workflow",
        "activity",
        "activity_id",
        "signal_key"
      ],
      "properties": {
        "event": {
          "const": "SignalWaitSatisfied"
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "signal_key": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "workflow",
        "activity",
        "activity_id",
        "waited_ms"
      ],
      "properties": {
        "event": {
          "const": "TimerWaitCompleted"
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "waited_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "activity",
        "activity_id",
        "branch",
        "decision_source"
      ],
      "properties": {
        "event": {
          "const": "BranchDecision"
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string",
          "enum": [
            "then",
            "else"
          ]
        },
        "decision_source": {
          "const": "deterministic_condition"
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "activity",
        "activity_id",
        "status",
        "classification"
      ],
      "properties": {
        "event": {
          "const": "LocalActivity"
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "executed"
        },
        "classification": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "activity",
        "activity_id",
        "mesh_op",
        "control"
      ],
      "properties": {
        "event": {
          "const": "MeshActivity"
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "mesh_op": {
          "type": "string",
          "enum": [
            "noop",
            "join",
            "snapshot",
            "heartbeat"
          ]
        },
        "control": {
          "type": "string",
          "minLength": 1
        },
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "node_count": {
          "type": "integer",
          "minimum": 0
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    {
      "required": [
        "event",
        "activity",
        "activity_id",
        "reason"
      ],
      "properties": {
        "event": {
          "const": "MeshActivitySkipped"
        },
        "activity": {
          "type": "string",
          "minLength": 1
        },
        "activity_id": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  ]
}
