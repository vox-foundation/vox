{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/contracts-index.schema.json",
  "title": "Vox contracts index",
  "type": "object",
  "required": ["schema_version", "contracts"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path", "owner", "kind"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9][a-z0-9.-]*$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["openapi-json", "openapi-yaml", "json-schema", "yaml", "json", "markdown"]
          },
          "description": {
            "type": "string"
          },
          "enforced_by": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
