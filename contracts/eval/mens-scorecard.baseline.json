{
  "schema_version": 1,
  "prompt_pack_version": "vox-mens-v1",
  "max_retries": 2,
  "conditions": [
    {
      "id": "base_qwen_http",
      "label": "Base Qwen via HTTP endpoint",
      "mode": "http_generate",
      "backend": "base",
      "model_id": "Qwen/Qwen3.5-4B",
      "adapter_revision": "",
      "server_url": "http://127.0.0.1:8080"
    },
    {
      "id": "best_qlora_fixture",
      "label": "Current best QLoRA fixture outputs",
      "mode": "fixture_file",
      "backend": "qlora",
      "model_id": "Qwen/Qwen3.5-4B+adapter",
      "adapter_revision": "manual",
      "fixture_dir": "mens/eval/fixtures/best_qlora"
    }
  ],
  "tasks": [
    {
      "id": "actor_ping",
      "prompt": "Create a Vox actor named Ping with state `count: Int` and `on inc() -> Int` that increments count and returns it.",
      "expected_contains": [
        "actor Ping",
        "on inc() -> Int"
      ],
      "semantic_expected_contains": [
        "ret",
        "count"
      ]
    },
    {
      "id": "http_route",
      "prompt": "Create a Vox HTTP GET route `/health` returning `{ ok: true }` using idiomatic Vox syntax.",
      "expected_contains": [
        "/health",
        "ok"
      ],
      "semantic_expected_contains": [
        "http get",
        "ret"
      ]
    }
  ]
}
