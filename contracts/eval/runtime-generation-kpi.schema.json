{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/eval/runtime-generation-kpi.schema.json",
  "title": "Runtime generation KPI",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "surface",
    "success",
    "validate_requested",
    "compile_pass",
    "canonical_pass",
    "attempts",
    "repair_stalled",
    "time_to_first_valid_ms",
    "output_tokens",
    "surface_contract_failures"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "vox_runtime_generation_kpi_v1"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "surface": {
      "type": "string",
      "enum": ["vox-cli", "mcp"]
    },
    "success": {
      "type": "boolean"
    },
    "validate_requested": {
      "type": "boolean"
    },
    "compile_pass": {
      "type": ["boolean", "null"]
    },
    "canonical_pass": {
      "type": ["boolean", "null"]
    },
    "attempts": {
      "type": "integer",
      "minimum": 1
    },
    "repair_stalled": {
      "type": "boolean"
    },
    "time_to_first_valid_ms": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "output_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "surface_contract_failures": {
      "type": "integer",
      "minimum": 0
    },
    "strictness_failures": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "canonicalization_failures": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "failure_category": {
      "type": ["string", "null"]
    }
  }
}
