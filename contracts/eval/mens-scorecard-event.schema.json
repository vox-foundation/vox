{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/eval/mens-scorecard-event.schema.json",
  "title": "Mens scorecard event row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "condition_id",
    "backend",
    "task_id",
    "attempts",
    "compile_pass_1",
    "compile_pass_n",
    "canonical_pass",
    "voxelized_strictness",
    "task_success",
    "semantic_task_success",
    "hir_error_count",
    "latency_ms",
    "repair_stalled",
    "tokens_in",
    "tokens_out",
    "placeholder_marker_hits",
    "trivial_placeholder_output",
    "construct_richness_score",
    "anti_stub_pass"
  ],
  "properties": {
    "condition_id": { "type": "string", "minLength": 1 },
    "backend": {
      "type": "string",
      "enum": ["base", "qlora", "burn", "other"]
    },
    "task_id": { "type": "string", "minLength": 1 },
    "attempts": { "type": "integer", "minimum": 1 },
    "compile_pass_1": { "type": "boolean" },
    "compile_pass_n": { "type": "boolean" },
    "repair_depth": { "type": ["integer", "null"], "minimum": 0 },
    "canonical_pass": { "type": "boolean" },
    "voxelized_strictness": { "type": "boolean" },
    "task_success": { "type": "boolean" },
    "semantic_task_success": { "type": "boolean" },
    "hir_error_count": { "type": "integer", "minimum": 0 },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "time_to_first_valid_ms": { "type": ["integer", "null"], "minimum": 0 },
    "repair_stalled": { "type": "boolean" },
    "tokens_in": { "type": "integer", "minimum": 0 },
    "tokens_out": { "type": "integer", "minimum": 0 },
    "placeholder_marker_hits": { "type": "integer", "minimum": 0 },
    "trivial_placeholder_output": { "type": "boolean" },
    "construct_richness_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "anti_stub_pass": { "type": "boolean" }
  }
}
