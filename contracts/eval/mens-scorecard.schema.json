{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/eval/mens-scorecard.schema.json",
  "title": "Mens scorecard benchmark spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "prompt_pack_version",
    "max_retries",
    "conditions",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "prompt_pack_version": {
      "type": "string",
      "minLength": 1
    },
    "max_retries": {
      "type": "integer",
      "minimum": 0,
      "maximum": 8
    },
    "conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "mode"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "type": "string",
            "enum": [
              "http_generate",
              "fixture_file"
            ]
          },
          "backend": {
            "type": "string",
            "enum": [
              "base",
              "qlora",
              "burn",
              "other"
            ]
          },
          "model_id": {
            "type": "string"
          },
          "adapter_revision": {
            "type": "string"
          },
          "server_url": {
            "type": "string"
          },
          "fixture_dir": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "mode": {
                  "const": "http_generate"
                }
              }
            },
            "then": {
              "required": [
                "server_url"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "mode": {
                  "const": "fixture_file"
                }
              }
            },
            "then": {
              "required": [
                "fixture_dir"
              ]
            }
          }
        ]
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "prompt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "expected_contains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "semantic_expected_contains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        }
      }
    }
  }
}
