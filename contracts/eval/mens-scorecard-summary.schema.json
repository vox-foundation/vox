{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/eval/mens-scorecard-summary.schema.json",
  "title": "Mens scorecard summary artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "prompt_pack_version",
    "git_sha",
    "run_started_utc",
    "spec_path",
    "conditions"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "vox_mens_scorecard_summary_v1"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "prompt_pack_version": {
      "type": "string",
      "minLength": 1
    },
    "git_sha": {
      "type": "string",
      "minLength": 1
    },
    "run_started_utc": {
      "type": "string",
      "minLength": 1
    },
    "spec_path": {
      "type": "string",
      "minLength": 1
    },
    "kpi_contract_alignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_generation_kpi_schema",
        "mens_scorecard_event_schema_id"
      ],
      "properties": {
        "runtime_generation_kpi_schema": {
          "type": "string",
          "const": "vox_runtime_generation_kpi_v1"
        },
        "mens_scorecard_event_schema_id": {
          "type": "string",
          "const": "https://vox-lang.org/schemas/eval/mens-scorecard-event.schema.json"
        }
      }
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "backend",
          "total_tasks",
          "compile_pass_at_1",
          "compile_pass_at_n",
          "canonical_pass",
          "voxelized_strictness",
          "task_success",
          "semantic_task_success",
          "repair_depth_mean",
          "repair_stall_rate",
          "time_to_first_valid_p50_ms",
          "latency_p50_ms",
          "latency_p95_ms",
          "tokens_in_total",
          "tokens_out_total",
          "placeholder_hits_total",
          "placeholder_event_rate",
          "trivial_placeholder_rate",
          "construct_richness_mean",
          "anti_stub_pass_rate"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "backend": {
            "type": "string",
            "enum": ["base", "qlora", "burn", "other"]
          },
          "model_id": { "type": ["string", "null"] },
          "adapter_revision": { "type": ["string", "null"] },
          "total_tasks": { "type": "integer", "minimum": 0 },
          "compile_pass_at_1": { "type": "number", "minimum": 0, "maximum": 1 },
          "compile_pass_at_n": { "type": "number", "minimum": 0, "maximum": 1 },
          "canonical_pass": { "type": "number", "minimum": 0, "maximum": 1 },
          "voxelized_strictness": { "type": "number", "minimum": 0, "maximum": 1 },
          "task_success": { "type": "number", "minimum": 0, "maximum": 1 },
          "semantic_task_success": { "type": "number", "minimum": 0, "maximum": 1 },
          "repair_depth_mean": { "type": "number", "minimum": 0 },
          "repair_stall_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "time_to_first_valid_p50_ms": { "type": "integer", "minimum": 0 },
          "latency_p50_ms": { "type": "integer", "minimum": 0 },
          "latency_p95_ms": { "type": "integer", "minimum": 0 },
          "tokens_in_total": { "type": "integer", "minimum": 0 },
          "tokens_out_total": { "type": "integer", "minimum": 0 },
          "placeholder_hits_total": { "type": "integer", "minimum": 0 },
          "placeholder_event_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "trivial_placeholder_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "construct_richness_mean": { "type": "number", "minimum": 0, "maximum": 1 },
          "anti_stub_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
