{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vox Visus: GUI Visual Rubric",
  "description": "Standardized schema for VLM-driven GUI bug detection and grounding validation.",
  "type": "object",
  "required": ["bugs", "timestamp", "viewport"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "viewport": {
      "type": "string",
      "description": "Viewport dimensions (e.g. 1280x800)"
    },
    "bugs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "severity", "coordinates", "description"],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "overlap",
              "clip",
              "contrast",
              "hydration",
              "truncation",
              "invisible_blocker",
              "layout_shift",
              "cross_browser"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "coordinates": {
            "type": "object",
            "required": ["x", "y", "w", "h"],
            "properties": {
              "x": { "type": "number", "description": "X coordinate in pixels" },
              "y": { "type": "number", "description": "Y coordinate in pixels" },
              "w": { "type": "number", "description": "Width in pixels" },
              "h": { "type": "number", "description": "Height in pixels" }
            }
          },
          "element_selector": {
            "type": "string",
            "description": "CSS selector or AXTree path of the offending element"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the visual defect"
          },
          "suggested_fix": {
            "type": "string",
            "description": "VLM-suggested CSS or structure fix (e.g. 'Use createPortal for this modal')"
          }
        }
      }
    }
  }
}
