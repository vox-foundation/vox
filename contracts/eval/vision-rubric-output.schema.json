{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/eval/vision-rubric-output.schema.json",
  "title": "Vox vision / DOM rubric tool output (stub v1)",
  "description": "Machine-checkable result from a future `vox_vision_rubric` / CI rubric lane. Validate outputs against this schema before quarantine or Mens ingest.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rubric_id",
    "verdict",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "rubric_id": {
      "type": "string",
      "minLength": 1
    },
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "image_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "model_id": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "inconclusive"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "skipped"
            ]
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "dom_a11y_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "notes": {
      "type": "string"
    }
  }
}
