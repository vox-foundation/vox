{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/eval/syntax-k-event.schema.json",
  "title": "Vox syntax K telemetry event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture_id",
    "target_kind",
    "raw_bytes",
    "compressor_results",
    "k_est_bytes",
    "toolchain_fingerprint"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "fixture_id": {
      "type": "string",
      "minLength": 1
    },
    "source_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "web_ir_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "target_kind": {
      "type": "string",
      "minLength": 1
    },
    "raw_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "compressor_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "profile", "compressed_bytes", "ratio"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["zstd", "bzip2", "gzip"]
          },
          "profile": {
            "type": "string",
            "minLength": 1
          },
          "compressed_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "ratio": {
            "type": "number",
            "minimum": 0.0
          }
        }
      }
    },
    "k_est_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "ncd_vs_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["per_compressor", "median"],
      "properties": {
        "per_compressor": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "value"],
            "properties": {
              "name": {
                "type": "string",
                "enum": ["zstd", "bzip2", "gzip"]
              },
              "value": {
                "type": "number"
              }
            }
          }
        },
        "median": {
          "type": "number"
        }
      }
    },
    "support_metrics": {
      "type": "object",
      "description": "Tooling metrics (lowering counts, representability, LLM-surface proxies, runtime projection digests).",
      "additionalProperties": true,
      "properties": {
        "representability": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "parse_ok": { "type": "boolean" },
            "hir_ok": { "type": "boolean" },
            "web_ir_validate_ok": { "type": "boolean" },
            "emit_preview_ok": { "type": ["boolean", "null"] },
            "first_failing_stage": { "type": ["string", "null"] }
          }
        },
        "llm_surface": {
          "type": "object",
          "additionalProperties": true
        },
        "runtime_projection": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "toolchain_fingerprint": {
      "type": "object",
      "additionalProperties": true,
      "required": ["compiler", "compressor_profiles"],
      "properties": {
        "compiler": {
          "type": "string",
          "minLength": 1
        },
        "compressor_profiles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "platform": {
          "type": "string"
        },
        "timestamp_unix_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
