{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/eval/external-serving-handoff.schema.json",
  "title": "External serving handoff artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "backend_family",
    "base_model",
    "tokenizer_source",
    "artifact_dir",
    "prompt_format"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "vox_external_serving_handoff_v1"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "backend_family": {
      "type": "string",
      "enum": ["vllm", "ollama", "hf-transformers", "openai-compatible", "other"]
    },
    "base_model": {
      "type": "string",
      "minLength": 1
    },
    "adapter_path": {
      "type": ["string", "null"]
    },
    "artifact_dir": {
      "type": "string",
      "minLength": 1
    },
    "tokenizer_source": {
      "type": "string",
      "minLength": 1
    },
    "prompt_format": {
      "type": "string",
      "minLength": 1
    },
    "openai_base_url": {
      "type": ["string", "null"]
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
