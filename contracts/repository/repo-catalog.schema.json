{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/contracts/repository/repo-catalog.schema.json",
  "title": "Vox Repo Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repositories"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "repositories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["display_name", "access_mode", "capabilities"],
        "properties": {
          "repository_id": {
            "type": ["string", "null"],
            "minLength": 1,
            "maxLength": 256,
            "description": "Stable repository id. Local entries may leave this null before refresh hydration."
          },
          "display_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "root_path": {
            "type": ["string", "null"],
            "minLength": 1,
            "maxLength": 4096,
            "description": "Absolute or workspace-relative local root path."
          },
          "origin_url": {
            "type": ["string", "null"],
            "maxLength": 4096
          },
          "provider": {
            "type": ["string", "null"],
            "maxLength": 128,
            "description": "Example: github, gitlab, bitbucket, sourcegraph, local."
          },
          "default_ref": {
            "type": ["string", "null"],
            "maxLength": 512
          },
          "access_mode": {
            "type": "string",
            "enum": [
              "local",
              "remote_mcp",
              "remote_git_host",
              "remote_search_service"
            ]
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "read_file",
                "list_files",
                "text_search",
                "semantic_search",
                "history_search"
              ]
            },
            "uniqueItems": true
          },
          "remote": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "mcp_url": {
                "type": ["string", "null"],
                "maxLength": 4096
              },
              "git_host_api_base": {
                "type": ["string", "null"],
                "maxLength": 4096
              },
              "git_host_owner": {
                "type": ["string", "null"],
                "maxLength": 256
              },
              "git_host_repo": {
                "type": ["string", "null"],
                "maxLength": 256
              },
              "search_service_url": {
                "type": ["string", "null"],
                "maxLength": 4096
              },
              "search_namespace": {
                "type": ["string", "null"],
                "maxLength": 512
              }
            }
          },
          "metadata": {
            "type": ["object", "null"],
            "description": "Optional implementation-specific annotations. Keep stable fields above canonical."
          }
        }
      }
    }
  }
}
