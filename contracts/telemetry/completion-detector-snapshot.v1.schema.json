{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vox-lang.org/contracts/telemetry/completion-detector-snapshot.v1.schema.json",
  "title": "per-detector rollup snapshot v1",
  "type": "object",
  "required": ["detector_id", "tier", "finding_count"],
  "additionalProperties": true,
  "properties": {
    "detector_id": { "type": "string" },
    "tier": { "type": "string" },
    "finding_count": { "type": "integer", "minimum": 0 },
    "block_state": { "type": "string" }
  }
}
