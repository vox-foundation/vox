{
  "x-vox-version": 1,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vox-lang.org/schemas/telemetry/events.v1.schema.json",
  "title": "Vox Telemetry Events Catalog",
  "type": "object",
  "properties": {
    "version": { "type": "integer" },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "schema_path": { "type": "string" },
          "owner_crate": { "type": "string" },
          "tier": { 
            "type": "string",
            "enum": ["A", "B", "C"]
          },
          "retention_days": { "type": "integer" },
          "description": { "type": "string" }
        },
        "required": ["id", "schema_path", "owner_crate", "tier", "retention_days", "description"]
      }
    }
  },
  "required": ["version", "events"]
}
