{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/contracts/orchestration/agent-vcs-facade.schema.json",
  "title": "AgentVcsFacadeJson",
  "description": "JSON shapes produced by vox_orchestrator::json_vcs_facade and mirrored by MCP vox_snapshot_*, vox_workspace_*, vox_oplog, and vox dei CLI.",
  "$defs": {
    "snapshot_list": {
      "type": "object",
      "required": ["snapshots"],
      "additionalProperties": true,
      "properties": {
        "snapshots": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "agent_id", "timestamp_ms", "description", "file_count"],
            "additionalProperties": true,
            "properties": {
              "id": { "type": "string" },
              "agent_id": { "type": "string" },
              "timestamp_ms": { "type": "integer" },
              "description": { "type": "string" },
              "file_count": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "workspace_status": {
      "type": "object",
      "required": ["has_workspace"],
      "additionalProperties": true,
      "properties": {
        "has_workspace": { "type": "boolean" },
        "modified_files": { "type": "array", "items": { "type": "string" } },
        "modified_count": { "type": "integer", "minimum": 0 },
        "base_snapshot": { "type": "string" },
        "active_change": { "type": ["string", "null"] }
      }
    },
    "oplog_list": {
      "type": "object",
      "required": ["operations"],
      "additionalProperties": true,
      "properties": {
        "operations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "agent_id", "timestamp_ms", "kind", "description", "undone"],
            "additionalProperties": true,
            "properties": {
              "id": { "type": "string" },
              "agent_id": { "type": "string" },
              "timestamp_ms": { "type": "integer" },
              "kind": { "type": "string" },
              "description": { "type": "string" },
              "undone": { "type": "boolean" }
            }
          }
        }
      }
    },
    "takeover_handoff": {
      "type": "object",
      "required": [
        "schema",
        "schema_version",
        "repository",
        "agent_id",
        "workspace",
        "snapshots",
        "oplog"
      ],
      "additionalProperties": true,
      "properties": {
        "schema": { "type": "string", "const": "vox_takeover_handoff_v1" },
        "schema_version": { "type": "integer", "const": 1 },
        "repository": {
          "type": "object",
          "required": ["root", "repository_id"],
          "additionalProperties": false,
          "properties": {
            "root": { "type": "string" },
            "repository_id": { "type": "string" }
          }
        },
        "agent_id": { "type": "integer", "minimum": 0 },
        "workspace": { "$ref": "#/$defs/workspace_status" },
        "snapshots": { "$ref": "#/$defs/snapshot_list" },
        "oplog": { "$ref": "#/$defs/oplog_list" }
      }
    }
  }
}
