{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/orchestration/orch-daemon-rpc-methods.schema.json",
  "title": "Vox orchestrator daemon JSON-line dispatch request",
  "description": "One JSON object per line on stdin/stdout or TCP (`id`, `method`, `params`) for `vox-orchestrator-d` (`orch.*`). Separate from DeI `ai.*` contracts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "method",
    "params"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Correlation id for request/response pairing."
    },
    "method": {
      "type": "string",
      "enum": [
        "orch.ping",
        "orch.status",
        "orch.task_status",
        "orch.spawn_agent",
        "orch.agent_ids",
        "orch.submit_task",
        "orch.complete_task",
        "orch.fail_task",
        "orch.cancel_task",
        "orch.reorder_task",
        "orch.drain_agent",
        "orch.rebalance",
        "orch.spawn_agent_ext",
        "orch.retire_agent",
        "orch.pause_agent",
        "orch.resume_agent",
        "orch.workspace_journey"
      ]
    },
    "params": {
      "type": "object",
      "description": "Method-specific payload; validated in daemon dispatch."
    }
  }
}
