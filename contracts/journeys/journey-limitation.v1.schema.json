{
  "x-vox-version": 1,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/contracts/journeys/journey-limitation.v1.schema.json",
  "title": "JourneyLimitationV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "category", "severity"],
  "properties": 
    "id":  "type": "string", "pattern": "^L-[0-9]3}$" },
    "title":  "type": "string" },
    "category":  "type": "string" },
    "severity":  "type": "string", "enum": ["info", "warn", "blocker"] },
    "mitigation_wave":  "type": "string" },
    "code_pointer":  "type": "string" }
  }
}
