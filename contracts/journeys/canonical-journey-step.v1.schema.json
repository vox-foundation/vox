{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/contracts/journeys/canonical-journey-step.v1.schema.json",
  "title": "CanonicalJourneyStepV1",
  "type": "object",
  "additionalProperties": true,
  "required": ["step_id", "ordinal", "actor", "maturity"],
  "properties": {
    "step_id": { "type": "string", "minLength": 1 },
    "ordinal": { "type": "integer", "minimum": 1 },
    "actor": {
      "type": "string",
      "enum": ["human", "cli", "runtime", "mcp", "ci", "daemon"]
    },
    "primary_operation_id": { "type": "string" },
    "persistence_hints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "limitation_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^L-[0-9]{3}$" }
    },
    "maturity": {
      "type": "string",
      "enum": ["stable", "beta", "spec_only"]
    }
  }
}
