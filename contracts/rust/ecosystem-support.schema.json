{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox/contracts/rust/ecosystem-support.schema.json",
  "title": "Vox Rust Ecosystem Support Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_from",
    "support_entries",
    "template_managed_dependencies",
    "wasi_unsupported_rust_imports"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "generated_from": {
      "type": "string",
      "minLength": 1
    },
    "support_entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "crate_family",
          "product_lane",
          "support_tier",
          "boundary_owner",
          "semantics_state",
          "capability_value",
          "debt_cost",
          "supported_targets",
          "decision",
          "notes"
        ],
        "properties": {
          "crate_family": {
            "type": "string",
            "pattern": "^[a-z0-9_+\\-\\.]+$"
          },
          "product_lane": {
            "type": "string",
            "enum": [
              "app",
              "workflow",
              "ai",
              "interop",
              "data",
              "platform"
            ]
          },
          "support_tier": {
            "type": "string",
            "enum": [
              "tier0",
              "tier1",
              "tier2",
              "tier3"
            ]
          },
          "boundary_owner": {
            "type": "string",
            "enum": [
              "WebIR",
              "AppContract",
              "RuntimeProjection",
              "builtin_registry",
              "approved_binding",
              "escape_hatch"
            ]
          },
          "semantics_state": {
            "type": "string",
            "enum": [
              "implemented",
              "partially_implemented",
              "planned",
              "docs_only"
            ]
          },
          "capability_value": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "debt_cost": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "supported_targets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "native",
                "wasi",
                "container"
              ]
            },
            "uniqueItems": true
          },
          "decision": {
            "type": "string",
            "enum": [
              "first_class",
              "internal_runtime_only",
              "escape_hatch_only",
              "deferred"
            ]
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "template_managed_dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "app",
        "script_native",
        "script_wasi"
      ],
      "properties": {
        "app": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-\\.]+$"
          },
          "uniqueItems": true
        },
        "script_native": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-\\.]+$"
          },
          "uniqueItems": true
        },
        "script_wasi": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-\\.]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "wasi_unsupported_rust_imports": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_\\-\\.]+$"
      },
      "uniqueItems": true
    }
  }
}
