{
  "x-vox-version": 1,
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox.local/contracts/reports/scaling-audit/findings-array.v1.schema.json",
  "title": "TOESTUB findings-only array (findings-latest.json)",
  "description": "Normalized artifact written by scaling-audit after stripping the CLI v1 envelope.",
  "type": "array",
  "items": 
    "type": "object",
    "required": ["rule_id", "rule_name", "severity", "file", "line", "column", "message"],
    "properties": 
      "rule_id":  "type": "string" },
      "rule_name":  "type": "string" },
      "severity":  "type": "string", "enum": ["info", "warning", "error", "critical"] },
      "file":  "type": "string" },
      "line":  "type": "integer", "minimum": 0 },
      "column":  "type": "integer", "minimum": 0 },
      "message":  "type": "string" },
      "suggestion":  "type": ["string", "null"] },
      "context":  "type": "string" },
      "confidence": 
        "oneOf": [
           "type": "string", "enum": ["high", "medium", "low"] },
           "type": "null" }
        ]
      }
    },
    "additionalProperties": true
  }
}
