{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/contracts/reports/ai-fixture-holes/ledger.v1.schema.json",
  "title": "AI fixture hole staleness ledger",
  "type": "object",
  "required": ["entries"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON Schema URL reference."
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cache_key", "stale"],
        "properties": {
          "cache_key": {
            "type": "string",
            "minLength": 1
          },
          "stale": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
