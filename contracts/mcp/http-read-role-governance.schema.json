{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vox-lang.org/schemas/mcp/http-read-role-governance.schema.json",
  "title": "MCP HTTP read-role governance profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "read_role_tools"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "read_role_tools": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "description": "Canonical MCP tool names allowed for HTTP read-role after metadata eligibility and global allowlist intersections."
    }
  }
}
