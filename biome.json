{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "include": [
      "docs-astro/src/**/*.{ts,tsx,js,jsx,astro}",
      "apps/vox-mental-tracker/src/**/*.{ts,tsx}",
      "tools/visualizer/src/**/*.{ts,tsx}",
      "crates/vox-codegen/codegen_ts/tests/**/*.ts"
    ],
    "ignore": [
      "**/node_modules/**",
      "**/.astro/**",
      "**/dist/**",
      "**/target/**"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsoleLog": "warn"
      },
      "complexity": {
        "noForEach": "off"
      }
    }
  },
  "formatter": {
    "enabled": false
  }
}
