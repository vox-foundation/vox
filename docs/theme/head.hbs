<!-- Global meta description fallback — overridden per-page by mdbook-metadata -->
<meta name="description" content="Vox is an AI-native, null-free programming language that compiles to Rust and TypeScript. Eliminate LLM hallucinations with a compiler-enforced type system.">
<!-- SEO: Per-page meta tags -->
<meta name="keywords" content="Vox, programming language, AI-native, full-stack, Rust, TypeScript, compiler, durable execution, actors, workflows, MCP">
<meta name="author" content="Bert Brainerd">
<meta name="robots" content="index, follow">

<!-- Canonical URL: JS sets it from window.location for accuracy; noscript uses the path hint -->
<link id="canonical-url" rel="canonical" href="https://vox-lang.org/">
<script>
  (function() {
    var canonical = document.getElementById('canonical-url');
    if (canonical) {
      var url = window.location.origin + window.location.pathname;
      canonical.href = url;
    }
  })();
</script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<script>
document.addEventListener("DOMContentLoaded", function() {
    const meta = document.querySelector('meta[name="last_updated"]');
    if (!meta) return;
    
    const lastUpdated = new Date(meta.content);
    const now = new Date();
    const diffDays = Math.floor((now - lastUpdated) / (1000 * 60 * 60 * 24));
    
    let statusClass = 'current';
    let statusText = 'Verified: ' + meta.content;
    
    if (diffDays > 180) {
        statusClass = 'critically-stale';
        statusText = 'Archival: ' + meta.content;
    } else if (diffDays > 90) {
        statusClass = 'stale';
        statusText = 'Review Needed: ' + meta.content;
    }
    
    const badge = document.createElement('div');
    badge.className = 'freshness-badge ' + statusClass;
    badge.innerText = statusText;
    
    const h1 = document.querySelector('h1');
    if (h1) {
        h1.parentNode.insertBefore(badge, h1.nextSibling);
    }
});
</script>

