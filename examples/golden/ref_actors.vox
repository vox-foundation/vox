// ANCHOR: basic_actor
actor Counter {
    let mutable count = 0;

    on increment() {
        count = count + 1;
        print("Count is " + count);
    }
}
// ANCHOR_END: basic_actor

// ANCHOR: spawn_and_send
fn run() {
    let c = spawn Counter();
    c.send increment();
}
// ANCHOR_END: spawn_and_send
