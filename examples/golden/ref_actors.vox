// ANCHOR: basic_actor
actor Counter {
    state count: int

    on increment(amount: int) to int {
        let next = count + amount
        count = next
        print("Count is " + next)
        return next
    }
}
// ANCHOR_END: basic_actor

// ANCHOR: spawn_and_send
fn run() {
    let c = spawn(Counter)
    c.increment(1)
}
// ANCHOR_END: spawn_and_send
