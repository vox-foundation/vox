// ---
// title: "Blog fullstack golden"
// description: "Minimal blog-shaped module: @table Post, @endpoint(kind: query) list, @endpoint(kind: mutation) publish, routes { } — exercises vox-client GET+POST with manifest."
// syntax_version: "0.5.0"
// status: golden
// category: example
// constructs: [@table, @endpoint(kind: query), @endpoint(kind: mutation), routes, component]
// last_validated: 2026-04-08
