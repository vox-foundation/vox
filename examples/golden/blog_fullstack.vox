// @training_prompt: Combine @table Post, a list @endpoint(kind: query), an @endpoint(kind: mutation), and a small routes tree for a tutorial-style blog slice.

@table type Post {
    title: str
}

@endpoint(kind: query) fn list_posts() to List[Post] {
    return db.Post.all()
}

@endpoint(kind: mutation) fn publish_post(title: str) to Result[Id[Post]] {
    let id = db.Post.insert({ title: title })?
    return Ok(id)
}

component BlogHome() {
    state n: int = 0
    view: column() {
        text() { "blog" }
        link(href="/edit") { "Edit posts" }
    }
}

component PostEditor() {
    state n: int = 0
    view: text() { "editor" }
}

routes {
    "/" to BlogHome
    "/edit" to PostEditor
}
