// ---
// title: "Agent Pipeline Example"
// description: "Multi-agent system with structured message types and worker actor state tracking."
// syntax_version: "0.8"
// status: golden
// category: example
// constructs: [message, agent, @agent_def, on, state]
// last_validated: 2026-03-24
// training_eligible: true
// training_weight: 1.0
// ---
// @training_prompt: Define a Vox message type and an agent definition for a multi-agent system
message TaskMessage {
    id: int
    payload: str
}

@agent_def
fn DataAgent() to str {
    tools: [read_file]
    memory: semantic
    ret "Ready"
}

agent WorkerAgent {
    state processed: int = 0
    
    on HandleTask(msg: TaskMessage) to str {
        processed = processed + 1
        ret "Task " + msg.id + " done"
    }
}
