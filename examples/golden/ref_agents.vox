// ANCHOR: basic_agent
agent Assistant {
    version "1.0.0"

    on greet(name: str) -> str {
        return "Hello " + name + ", how can I assist you today?"
    }

    migrate from "0.9.0" {
        print("Migrating data...")
    }
}
// ANCHOR_END: basic_agent

// ANCHOR: stateful_agent
agent MemoryBank {
    entries: List[str]

    on add(item: str) {
        entries = entries.append(item)
    }

    on recall() -> List[str] {
        return entries
    }
}
// ANCHOR_END: stateful_agent
