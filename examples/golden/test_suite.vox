// ---
# @training_prompt: Write a Vox @test that uses helper fns and assert.
// ANCHOR: display
fn setup_user() to list[str] {
    ret ["alice", "bob"]
}

fn mock_db_read() to str {
    ret "mock_data"
}

@test
fn test_user_count() to Unit {
    let users = setup_user()
    assert(len(users) > 0)
    let db_val = mock_db_read()
    assert(db_val is "mock_data")
}
// ANCHOR_END: display
