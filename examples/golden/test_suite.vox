// ---
// title: "Test Suite Example"
// description: "@test with plain helper fns (@fixture/@mock are not tokenized; use regular fn helpers)."
// syntax_version: "0.8"
// status: golden
// category: example
// constructs: [@test, assert, fn]
// last_validated: 2026-03-26
// training_eligible: true
