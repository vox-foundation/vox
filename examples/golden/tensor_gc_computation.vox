// vox:skip
/// This golden example demonstrates how Per-Actor GC drastically reduces K-Complexity 
/// for LLM Generation. MENS agents can generate pure mathematical logic without 
/// wrestling with rust's borrow-checker or arc/mutex allocations. The backend 
/// compiler automatically lowers `let` bindings to the restricted local `ActorHeap`.

fn MathWorker_compute_weights(a: Tensor[2], b: Tensor[2]) to Tensor[2] {
    // Look how clean this is. No `.clone()`, no `Arc<Mutex>`, no explicit 
    // dimension tracking allocators.
    
    // Lowered as: `let intermediate = ctx.heap.allocate(a.matmul(&b));`
    let intermediate = a * b; 
    
    // Lowered as: `let bias = ctx.heap.allocate(Tensor(0.5));`
    let bias = 0.5;

    let result = intermediate + bias;

    // Sent back across the mailbox. Uses `burn` reference-counting 
    // handle duplication natively, skipping deep-copies.
    return result;
}
