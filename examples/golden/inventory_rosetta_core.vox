// ---
// title: "Inventory Rosetta Core"
// description: "Inventory merge core: ADT errors, pure merge logic, and @table persistence primitives for Rosetta comparison demos."
// syntax_version: "0.8"
// status: golden
// category: example
// constructs: [type, match, fn, @table, @endpoint(kind: query), @endpoint(kind: mutation), db]
// last_validated: 2026-04-06
// training_eligible: true
