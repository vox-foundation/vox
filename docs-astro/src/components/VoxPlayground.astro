---
interface Props {
  initialCode?: string;
}
const { initialCode = '// Write some Vox code here\nfn main() {\n    print("Hello, Vox!")\n}\n' } = Astro.props;
---

<vox-playground data-initial-code={initialCode}>
  <div class="vox-playground">
    <div class="notice-banner">
      <strong>Note:</strong> Live execution is currently disabled on the static GitHub Pages deployment. A dedicated sandbox backend is pending in a future update.
    </div>
    <div class="editor-container">
      <textarea class="code-editor" spellcheck="false" aria-label="Vox Code Editor"></textarea>
    </div>
    <div class="actions">
      <button class="run-btn" disabled title="Pending backend deployment">Run Code</button>
      <span class="status-msg">Execution Offline</span>
    </div>
    <div class="output-container">
      <pre class="output-display">Waiting for backend...</pre>
    </div>
  </div>
</vox-playground>

<style>
  .vox-playground {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    overflow: hidden;
    margin: 1.5rem 0;
    background-color: var(--sl-color-bg);
  }
  .notice-banner {
    background-color: var(--sl-color-orange-low);
    color: var(--sl-color-orange-high);
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .editor-container {
    border-bottom: 1px solid var(--sl-color-gray-5);
  }
  .code-editor {
    width: 100%;
    min-height: 200px;
    padding: 1rem;
    background: var(--sl-color-black);
    color: var(--sl-color-gray-2);
    font-family: var(--sl-font-mono);
    font-size: 0.875rem;
    border: none;
    resize: vertical;
    outline: none;
    box-sizing: border-box;
  }
  .code-editor:focus {
    color: var(--sl-color-white);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background-color: var(--sl-color-gray-6);
  }
  .run-btn {
    background-color: var(--sl-color-accent);
    color: var(--sl-color-text-invert);
    border: none;
    border-radius: 0.25rem;
    padding: 0.5rem 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
  }
  .run-btn:hover {
    background-color: var(--sl-color-accent-high);
  }
  .run-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .status-msg {
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
  }
  .output-container {
    padding: 1rem;
    background-color: var(--sl-color-black);
    border-top: 1px solid var(--sl-color-gray-5);
  }
  .output-display {
    margin: 0;
    color: var(--sl-color-gray-3);
    font-family: var(--sl-font-mono);
    font-size: 0.875rem;
    white-space: pre-wrap;
    word-break: break-all;
  }
</style>

<script>
  class VoxPlayground extends HTMLElement {
    constructor() {
      super();
      const initialCode = this.dataset.initialCode || "";
      const editor = this.querySelector(".code-editor");
      const runBtn = this.querySelector(".run-btn");
      const statusMsg = this.querySelector(".status-msg");
      const outputDisplay = this.querySelector(".output-display");

      if (editor) editor.value = initialCode;

      if (runBtn) {
        runBtn.addEventListener("click", async () => {
          const code = editor.value;
          if (!code.trim()) return;

          runBtn.disabled = true;
          statusMsg.textContent = "Executing...";
          outputDisplay.textContent = "";

          try {
            // Default to localhost for local docs preview, but allow overrides
            const endpoint = localStorage.getItem("VOX_EVAL_ENDPOINT") || "http://127.0.0.1:3921/v1/eval";
            const token = localStorage.getItem("VOX_EVAL_TOKEN") || "";

            const headers = {
              "Content-Type": "application/json",
            };
            if (token) {
              headers["Authorization"] = `Bearer ${token}`;
            }

            const res = await fetch(endpoint, {
              method: "POST",
              headers,
              body: JSON.stringify({ code })
            });

            if (!res.ok) {
              const errJson = await res.json().catch(() => null);
              throw new Error(errJson?.error || `HTTP ${res.status}`);
            }

            const data = await res.json();
            if (data.error) {
              outputDisplay.textContent = `Error: ${data.error}\n\n${data.stderr}`;
              outputDisplay.style.color = "var(--sl-color-text-error, #f87171)";
            } else {
              let out = data.stdout || "";
              if (data.stderr) out += `\n[stderr]\n${data.stderr}`;
              outputDisplay.textContent = out || "(no output)";
              outputDisplay.style.color = data.success ? "var(--sl-color-gray-2)" : "var(--sl-color-text-error, #f87171)";
            }
            statusMsg.textContent = "Done";
          } catch (err) {
            outputDisplay.textContent = `Execution Failed: ${err.message}`;
            outputDisplay.style.color = "var(--sl-color-text-error, #f87171)";
            statusMsg.textContent = "Error";
          } finally {
            runBtn.disabled = false;
          }
        });
      }
    }
  }

  customElements.define("vox-playground", VoxPlayground);
</script>
