---
interface Props {
  initialCode?: string;
}
const { initialCode = '// Write some Vox code here\nfn main() {\n    print("Hello, Vox!")\n}\n' } = Astro.props;
---

<vox-playground data-initial-code={initialCode}>
  <div class="vox-playground">
    <!-- Shown only when backend health probe succeeds (JS enables it) -->
    <div class="live-ui" style="display:none">
      <div class="editor-container">
        <textarea class="code-editor" spellcheck="false" aria-label="Vox Code Editor"></textarea>
      </div>
      <div class="actions">
        <button class="run-btn" aria-label="Run Vox code">Run</button>
        <span class="status-msg"></span>
      </div>
      <div class="output-container">
        <pre class="output-display"></pre>
      </div>
    </div>

    <!-- Default state when backend is offline: clean static code demo, no broken banner -->
    <div class="static-demo">
      <div class="demo-label">Vox — Language at a Glance</div>
      <pre class="demo-code"><code>// One declaration → schema, API, typed client
@table type Task &#123;
    title:    str
    done:     bool
    priority: int
&#125;

// Compile-enforced: every caller handles both branches
@endpoint(kind: query)
fn get_tasks() to List[Task] &#123;
    return db.Task.all()
&#125;

// Expose to AI agents via MCP
@mcp.tool "Mark a task complete"
fn complete(id: Id[Task]) to Result[Unit] &#123;
    db.Task.delete(id)
    return Ok(Unit)
&#125;</code></pre>
      <div class="demo-footer">
        <span class="demo-note">Live execution coming soon — <a href="/tutorials/tut-getting-started/">install Vox locally</a> to run code now.</span>
      </div>
    </div>
  </div>
</vox-playground>

<style>
  .vox-playground {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    overflow: hidden;
    margin: 1.5rem 0;
    background-color: var(--sl-color-bg);
  }

  /* ── Live editor (hidden until backend confirms healthy) ── */
  .editor-container {
    border-bottom: 1px solid var(--sl-color-gray-5);
  }
  .code-editor {
    width: 100%;
    min-height: 200px;
    padding: 1rem;
    background: var(--sl-color-black);
    color: var(--sl-color-gray-2);
    font-family: var(--sl-font-mono);
    font-size: 0.875rem;
    border: none;
    resize: vertical;
    outline: none;
    box-sizing: border-box;
  }
  .code-editor:focus {
    color: var(--sl-color-white);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background-color: var(--sl-color-gray-6);
  }
  .run-btn {
    background-color: var(--sl-color-accent);
    color: var(--sl-color-text-invert);
    border: none;
    border-radius: 0.25rem;
    padding: 0.5rem 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
  }
  .run-btn:hover { background-color: var(--sl-color-accent-high); }
  .run-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .status-msg {
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
  }
  .output-container {
    padding: 1rem;
    background-color: var(--sl-color-black);
    border-top: 1px solid var(--sl-color-gray-5);
  }
  .output-display {
    margin: 0;
    color: var(--sl-color-gray-3);
    font-family: var(--sl-font-mono);
    font-size: 0.875rem;
    white-space: pre-wrap;
    word-break: break-all;
  }

  /* ── Static demo (shown when backend is offline — the default) ── */
  .static-demo {
    background: var(--sl-color-black);
  }
  .demo-label {
    padding: 0.6rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    border-bottom: 1px solid var(--sl-color-gray-5);
  }
  .demo-code {
    margin: 0;
    padding: 1.25rem 1rem;
    overflow-x: auto;
  }
  .demo-code code {
    font-family: var(--sl-font-mono);
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
    white-space: pre;
  }
  .demo-footer {
    padding: 0.6rem 1rem;
    border-top: 1px solid var(--sl-color-gray-5);
    background-color: var(--sl-color-gray-6);
  }
  .demo-note {
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
  }
  .demo-note a {
    color: var(--sl-color-accent);
    text-decoration: none;
  }
  .demo-note a:hover { text-decoration: underline; }
</style>

<script>
  class VoxPlayground extends HTMLElement {
    constructor() {
      super();
      const initialCode = this.dataset.initialCode || '';
      const liveUi = this.querySelector('.live-ui');
      const staticDemo = this.querySelector('.static-demo');
      const editor = this.querySelector('.code-editor');
      const runBtn = this.querySelector('.run-btn');
      const statusMsg = this.querySelector('.status-msg');
      const outputDisplay = this.querySelector('.output-display');

      const evalUrl =
        import.meta.env?.PUBLIC_VOX_EVAL_ENDPOINT ||
        localStorage.getItem('VOX_EVAL_ENDPOINT') ||
        'https://eval.vox-lang.org/v1/eval';
      const healthUrl = evalUrl.replace('/v1/eval', '/health');

      // Probe backend; swap to live editor only if healthy
      fetch(healthUrl, { signal: AbortSignal.timeout(2500) })
        .then((res) => {
          if (!res.ok) throw new Error('unhealthy');
          if (staticDemo) staticDemo.style.display = 'none';
          if (liveUi) liveUi.style.display = '';
          if (editor) editor.value = initialCode;
          if (outputDisplay) outputDisplay.textContent = 'Ready.';
        })
        .catch(() => {
          // Remain in static-demo state — intentional, no banner needed
        });

      if (runBtn) {
        runBtn.addEventListener('click', async () => {
          const code = editor.value;
          if (!code.trim()) return;
          runBtn.disabled = true;
          statusMsg.textContent = 'Executing…';
          outputDisplay.textContent = '';

          try {
            const token = localStorage.getItem('VOX_EVAL_TOKEN') || '';
            const headers = { 'Content-Type': 'application/json' };
            if (token) headers['Authorization'] = `Bearer ${token}`;

            const res = await fetch(evalUrl, {
              method: 'POST',
              headers,
              body: JSON.stringify({ code }),
            });

            if (!res.ok) {
              const errJson = await res.json().catch(() => null);
              throw new Error(errJson?.error || `HTTP ${res.status}`);
            }

            const data = await res.json();
            if (data.error) {
              outputDisplay.textContent = `Error: ${data.error}\n\n${data.stderr}`;
              outputDisplay.style.color = 'var(--sl-color-text-error, #f87171)';
            } else {
              let out = data.stdout || '';
              if (data.stderr) out += `\n[stderr]\n${data.stderr}`;
              outputDisplay.textContent = out || '(no output)';
              outputDisplay.style.color = data.success
                ? 'var(--sl-color-gray-2)'
                : 'var(--sl-color-text-error, #f87171)';
            }
            statusMsg.textContent = 'Done';
          } catch (err) {
            outputDisplay.textContent = `Execution failed: ${err.message}`;
            outputDisplay.style.color = 'var(--sl-color-text-error, #f87171)';
            statusMsg.textContent = 'Error';
          } finally {
            runBtn.disabled = false;
          }
        });
      }
    }
  }

  customElements.define('vox-playground', VoxPlayground);
</script>
