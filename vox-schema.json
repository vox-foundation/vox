{
  "project": "Vox",
  "version": "1.0.0",
  "description": "Architectual Single Source of Truth for File Paths and Governance",
  "thresholds": {
    "god_object": {
      "max_lines": 500,
      "max_methods": 12,
      "max_trait_impls_per_file": 8
    },
    "sprawl": {
      "max_files_per_dir": 20,
      "max_nesting_depth": 5,
      "forbidden_names": [
        "utils.rs",
        "helpers.ts",
        "misc.py",
        "common.vox"
      ]
    }
  },
  "crates": {
    "vox-audio-ingress": {
      "role": "Workspace member: vox-audio-ingress",
      "path_pattern": "crates/vox-audio-ingress/**/*.rs"
